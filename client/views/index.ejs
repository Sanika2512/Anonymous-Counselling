<% if (locals.currentUser) { %>
<script>
const wallState = {
    posts: [],
    categories: [],
    savedOnly: false,
    unread: 0,
    currentUserRole: '<%= currentUser.role %>',
    canCreatePost: <%= currentUser.role === 'student' ? 'true' : 'false' %>
};

const wallEls = {
    posts: document.getElementById('confessionPosts'),
    search: document.getElementById('wallSearch'),
    category: document.getElementById('wallCategory'),
    status: document.getElementById('wallStatus'),
    sort: document.getElementById('wallSort'),
    createCategory: document.getElementById('confessionCategory'),
    form: document.getElementById('confessionForm'),
    all: document.getElementById('showAllPosts'),
    saved: document.getElementById('showSavedPosts'),
    bell: document.getElementById('wallNotificationBell'),
    count: document.getElementById('wallNotificationCount')
};

function wallEscape(value) {
    return String(value || '').replace(/[&<>"']/g, char => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#039;'
    }[char]));
}

function wallDate(value) {
    return new Date(value).toLocaleString([], { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
}

function wallToast(message, type = 'success') {
    const toast = document.createElement('div');
    toast.style.cssText = `position:fixed;right:24px;bottom:24px;z-index:99999;background:${type === 'error' ? '#ef4444' : '#10b981'};color:#fff;padding:12px 18px;border-radius:999px;font-weight:700;box-shadow:0 14px 35px rgba(15,23,42,.18);`;
    toast.textContent = message;
    document.body.appendChild(toast);
    setTimeout(() => toast.remove(), 2600);
}

function mediaMarkup(media = []) {
    if (!media.length) return '';
    return `<div class="wall-media">${media.map(item => {
        const url = wallEscape(item.url);
        if (item.type === 'image') return `<img src="${url}" alt="Post media" onclick="window.open('${url}','_blank')">`;
        if (item.type === 'video') return `<video src="${url}" controls></video>`;
        if (item.type === 'audio') return `<audio src="${url}" controls style="width:100%;"></audio>`;
        return `<a class="btn btn-light border" href="${url}" download><i class="fas fa-paperclip me-1"></i>${wallEscape(item.originalName || 'Attachment')}</a>`;
    }).join('')}</div>`;
}

function replyMarkup(post, reply) {
    const indent = reply.parentReply ? '28px' : '0';
    return `<div class="wall-reply ${reply.role === 'counselor' ? 'counselor' : ''}" style="--reply-indent:${indent}">
        <div class="wall-reply-meta">
            <div><strong>${wallEscape(reply.anonymousId)}</strong> ${reply.role === 'counselor' ? '<span class="wall-chip"><i class="fas fa-check-circle me-1"></i>Verified Counselor</span>' : ''} ${reply.isHelpfulAnswer ? '<span class="wall-chip resolved"><i class="fas fa-check me-1"></i>Most Helpful</span>' : ''}</div>
            <small class="text-muted">${wallDate(reply.createdAt)}</small>
        </div>
        <p class="mb-2 mt-2">${wallEscape(reply.body)}</p>
        <div class="d-flex gap-2 flex-wrap">
            <button class="wall-action-btn" onclick="focusReply('${post.id}', '${reply.id}')"><i class="fas fa-reply me-1"></i>Reply</button>
            ${post.isOwner ? `<button class="wall-action-btn" onclick="markHelpful('${post.id}', '${reply.id}')"><i class="fas fa-star me-1"></i>Helpful</button>` : ''}
            ${reply.isOwner ? `<button class="wall-action-btn" onclick="editReply('${post.id}', '${reply.id}', '${wallEscape(reply.body).replace(/'/g, "\\'")}')"><i class="fas fa-edit me-1"></i>Edit</button><button class="wall-action-btn" onclick="deleteReply('${post.id}', '${reply.id}')"><i class="fas fa-trash me-1"></i>Delete</button>` : ''}
        </div>
    </div>`;
}

function postMarkup(post) {
    const sentimentClass = post.sentiment === 'distressed' ? 'distressed' : post.sentiment === 'positive' ? 'positive' : '';
    return `<article class="wall-card" id="post-${post.id}">
        <div class="wall-card-header">
            <div>
                <span class="wall-anon">${wallEscape(post.anonymousId)}</span>
                <span class="wall-chip">${wallEscape(post.category)}</span>
                <span class="wall-chip ${sentimentClass}">${wallEscape(post.sentiment)}</span>
                ${post.status === 'resolved' ? '<span class="wall-chip resolved">Resolved</span>' : ''}
                ${post.moderation?.flagged ? '<span class="wall-chip distressed">Flagged for review</span>' : ''}
            </div>
            <small class="text-muted">${wallDate(post.createdAt)}</small>
        </div>
        <h3>${wallEscape(post.title)}</h3>
        <p>${wallEscape(post.description)}</p>
        ${mediaMarkup(post.media)}
        <div class="wall-recommendations">${(post.recommendations || []).map(item => `<span class="wall-chip"><i class="fas fa-leaf me-1"></i>${wallEscape(item)}</span>`).join('')}</div>
        <div class="wall-actions">
            <div class="d-flex gap-2 flex-wrap">
                ${reactionButton(post, 'support', 'heart', 'Support')}
                ${reactionButton(post, 'meToo', 'handshake', 'Me Too')}
                ${reactionButton(post, 'helpful', 'lightbulb', 'Helpful')}
                ${reactionButton(post, 'stayStrong', 'hands-praying', 'Stay Strong')}
                <button class="wall-action-btn ${post.saved ? 'active' : ''}" onclick="toggleSave('${post.id}')"><i class="fas fa-bookmark me-1"></i>${post.saved ? 'Saved' : 'Save'}</button>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                ${post.isOwner ? `<button class="wall-action-btn" onclick="toggleResolved('${post.id}')"><i class="fas fa-check me-1"></i>${post.status === 'resolved' ? 'Reopen' : 'Resolve'}</button><button class="wall-action-btn" onclick="editPost('${post.id}')"><i class="fas fa-edit me-1"></i>Edit</button><button class="wall-action-btn" onclick="deletePost('${post.id}')"><i class="fas fa-trash me-1"></i>Delete</button>` : ''}
            </div>
        </div>
        <div class="wall-replies">
            <strong>${post.replyCount} replies</strong>
            ${(post.replies || []).map(reply => replyMarkup(post, reply)).join('')}
            <form class="d-flex gap-2 flex-wrap" onsubmit="submitReply(event, '${post.id}')">
                <input type="hidden" name="parentReply">
                <input class="form-control flex-grow-1" name="body" placeholder="${wallState.currentUserRole === 'counselor' ? 'Give guidance as a verified counselor...' : 'Reply anonymously...'}" required>
                ${wallState.currentUserRole === 'counselor' ? '<label class="d-flex align-items-center gap-1 small"><input type="checkbox" name="isCounselorRecommendation"> Resource</label>' : ''}
                <button class="btn btn-primary" type="submit"><i class="fas fa-paper-plane"></i></button>
            </form>
        </div>
    </article>`;
}

function reactionButton(post, key, icon, label) {
    return `<button class="wall-action-btn ${post.myReactions?.[key] ? 'active' : ''}" onclick="toggleReaction('${post.id}', '${key}')"><i class="fas fa-${icon} me-1"></i>${label} ${post.reactionCounts?.[key] || 0}</button>`;
}

function renderWall() {
    if (!wallEls.posts) return;
    if (!wallState.posts.length) {
        wallEls.posts.innerHTML = '<div class="wall-empty"><i class="fas fa-comments fa-2x mb-3 text-primary"></i><h4>No posts yet</h4><p class="mb-0">Start the first anonymous discussion.</p></div>';
        return;
    }
    wallEls.posts.innerHTML = wallState.posts.map(postMarkup).join('');
    renderSidebar();
}

function renderSidebar() {
    const trending = [...wallState.posts].sort((a, b) => b.replyCount - a.replyCount).slice(0, 4);
    const helpful = [...wallState.posts].sort((a, b) => (b.reactionCounts?.helpful || 0) - (a.reactionCounts?.helpful || 0)).slice(0, 4);
    document.getElementById('wallTrending').innerHTML = trending.map(p => `<div class="wall-stat"><span>${wallEscape(p.category)}</span><strong>${p.replyCount}</strong></div>`).join('') || '<p class="text-muted mb-0">No activity yet.</p>';
    document.getElementById('wallHelpful').innerHTML = helpful.map(p => `<div class="mb-2"><strong>${wallEscape(p.title)}</strong><div class="text-muted small">${p.reactionCounts?.helpful || 0} helpful reactions</div></div>`).join('') || '<p class="text-muted mb-0">No helpful posts yet.</p>';
}

function fillCategories(categories) {
    [wallEls.category, wallState.canCreatePost ? wallEls.createCategory : null].forEach(select => {
        if (!select || select.dataset.ready) return;
        const first = select.id === 'confessionCategory' ? '<option value="">Auto detect</option>' : '<option value="">All categories</option>';
        select.innerHTML = first + categories.map(c => `<option value="${wallEscape(c)}">${wallEscape(c)}</option>`).join('');
        select.dataset.ready = 'true';
    });
}

async function loadWall() {
    const params = new URLSearchParams();
    if (wallEls.search?.value.trim()) params.set('search', wallEls.search.value.trim());
    if (wallEls.category?.value) params.set('category', wallEls.category.value);
    if (wallEls.status?.value) params.set('status', wallEls.status.value);
    if (wallEls.sort?.value) params.set('sort', wallEls.sort.value);
    if (wallState.savedOnly) params.set('saved', 'true');
    const res = await fetch(`/api/confessions?${params.toString()}`, { credentials: 'same-origin' });
    const data = await res.json();
    if (!data.success) throw new Error(data.message || 'Could not load wall');
    wallState.posts = data.posts || [];
    wallState.categories = data.categories || [];
    fillCategories(wallState.categories);
    document.getElementById('wallStatPosts').textContent = data.stats.posts || 0;
    document.getElementById('wallStatResolved').textContent = data.stats.resolved || 0;
    document.getElementById('wallStatReplies').textContent = data.stats.replies || 0;
    renderWall();
}

async function wallRequest(url, options = {}) {
    const res = await fetch(url, { credentials: 'same-origin', ...options });
    const data = await res.json();
    if (!data.success) throw new Error(data.message || 'Request failed');
    if (data.post) upsertPost(data.post);
    return data;
}

function upsertPost(post) {
    const index = wallState.posts.findIndex(item => String(item.id) === String(post.id));
    if (index >= 0) wallState.posts[index] = post;
    else wallState.posts.unshift(post);
    if (wallState.savedOnly && !post.saved) wallState.posts = wallState.posts.filter(item => String(item.id) !== String(post.id));
    renderWall();
}

async function toggleReaction(postId, reaction) { try { await wallRequest(`/api/confessions/${postId}/reactions/${reaction}`, { method: 'POST' }); } catch (e) { wallToast(e.message, 'error'); } }
async function toggleSave(postId) { try { await wallRequest(`/api/confessions/${postId}/save`, { method: 'POST' }); } catch (e) { wallToast(e.message, 'error'); } }
async function toggleResolved(postId) { try { await wallRequest(`/api/confessions/${postId}/resolve`, { method: 'POST' }); } catch (e) { wallToast(e.message, 'error'); } }
async function markHelpful(postId, replyId) { try { await wallRequest(`/api/confessions/${postId}/helpful/${replyId}`, { method: 'POST' }); } catch (e) { wallToast(e.message, 'error'); } }

function focusReply(postId, replyId) {
    const form = document.querySelector(`#post-${postId} form`);
    if (!form) return;
    form.parentReply.value = replyId;
    form.body.placeholder = 'Replying in thread...';
    form.body.focus();
}

async function submitReply(event, postId) {
    event.preventDefault();
    const form = event.currentTarget;
    try {
        await wallRequest(`/api/confessions/${postId}/replies`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                body: form.body.value,
                parentReply: form.parentReply.value,
                isCounselorRecommendation: !!form.isCounselorRecommendation?.checked
            })
        });
        form.reset();
        form.parentReply.value = '';
    } catch (e) { wallToast(e.message, 'error'); }
}

async function editReply(postId, replyId, currentBody) {
    const body = prompt('Edit reply', currentBody);
    if (!body) return;
    try { await wallRequest(`/api/confessions/${postId}/replies/${replyId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ body }) }); } catch (e) { wallToast(e.message, 'error'); }
}

async function deleteReply(postId, replyId) {
    if (!confirm('Delete this reply?')) return;
    try { await wallRequest(`/api/confessions/${postId}/replies/${replyId}`, { method: 'DELETE' }); } catch (e) { wallToast(e.message, 'error'); }
}

async function editPost(postId) {
    const post = wallState.posts.find(item => String(item.id) === String(postId));
    if (!post) return;
    const title = prompt('Edit title', post.title);
    if (!title) return;
    const description = prompt('Edit description', post.description);
    if (!description) return;
    try { await wallRequest(`/api/confessions/${postId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ title, description, category: post.category }) }); } catch (e) { wallToast(e.message, 'error'); }
}

async function deletePost(postId) {
    if (!confirm('Delete this post?')) return;
    try {
        await wallRequest(`/api/confessions/${postId}`, { method: 'DELETE' });
        wallState.posts = wallState.posts.filter(item => String(item.id) !== String(postId));
        renderWall();
    } catch (e) { wallToast(e.message, 'error'); }
}

document.addEventListener('DOMContentLoaded', () => {
    loadWall().catch(e => wallToast(e.message, 'error'));
    [wallEls.search, wallEls.category, wallEls.status, wallEls.sort].forEach(el => el?.addEventListener('input', () => loadWall().catch(e => wallToast(e.message, 'error'))));
    wallEls.all?.addEventListener('click', () => { wallState.savedOnly = false; wallEls.all.classList.add('active'); wallEls.saved.classList.remove('active'); loadWall(); });
    wallEls.saved?.addEventListener('click', () => { wallState.savedOnly = true; wallEls.saved.classList.add('active'); wallEls.all.classList.remove('active'); loadWall(); });
    if (wallState.canCreatePost) wallEls.form?.addEventListener('submit', async event => {
        event.preventDefault();
        const button = wallEls.form.querySelector('button[type="submit"]');
        button.disabled = true;
        try {
            const data = await wallRequest('/api/confessions', { method: 'POST', body: new FormData(wallEls.form) });
            wallEls.form.reset();
            bootstrap.Modal.getInstance(document.getElementById('confessionModal'))?.hide();
            wallToast('Post created anonymously.');
            upsertPost(data.post);
        } catch (e) {
            wallToast(e.message, 'error');
        } finally {
            button.disabled = false;
        }
    });

    if (typeof io !== 'undefined') {
        const wallSocket = io({ auth: { userId: '<%= currentUser._id %>', role: '<%= currentUser.role %>' } });
        wallSocket.on('connect', () => wallSocket.emit('join-confession-wall'));
        wallSocket.on('confession:new', upsertPost);
        wallSocket.on('confession:updated', upsertPost);
        wallSocket.on('confession:deleted', payload => { wallState.posts = wallState.posts.filter(item => String(item.id) !== String(payload.id)); renderWall(); });
        wallSocket.on('wall-notification', payload => {
            wallState.unread += 1;
            wallEls.count.textContent = wallState.unread;
            wallEls.count.classList.remove('d-none');
            wallToast(payload.message || 'New wall notification');
        });
        wallEls.bell?.addEventListener('click', () => {
            wallState.unread = 0;
            wallEls.count.classList.add('d-none');
            wallEls.count.textContent = '0';
        });
    }
});
</script>
<% } %>
<script>
// Mood booster messages
const moodMessages = [
    "You're stronger than you think! ðŸ’ª",
    "This too shall pass ðŸŒˆ",
    "Take a deep breath ðŸŒ¬ï¸",
    "You matter! â¤ï¸",
    "Small steps are still progress ðŸ‘£",
    "It's okay to not be okay ðŸŒ»",
    "You're doing amazing! âœ¨",
    "Hope is on the way ðŸŒ…"
];

let messageIndex = 0;

function showMoodMessage() {
    const messageEl = document.getElementById('moodMessage');
    messageEl.style.opacity = '1';
    messageEl.style.visibility = 'visible';
    
    // Cycle through messages
    messageEl.textContent = moodMessages[messageIndex];
    messageIndex = (messageIndex + 1) % moodMessages.length;
    
    // Hide after 3 seconds
    setTimeout(() => {
        messageEl.style.opacity = '0';
        messageEl.style.visibility = 'hidden';
    }, 3000);
    
    // Play gentle sound
    playGentleSound();
}

function playGentleSound() {
    const audio = new Audio('data:audio/wav;base64,UklGRlwAAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YVAAAAA8AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA'); // Silent audio
    audio.volume = 0.1;
    audio.play().catch(e => {});
}

// Breathing exercise
function startBreathing() {
    const btn = document.querySelector('.breathing-btn');
    const originalHTML = btn.innerHTML;
    
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
    
    const steps = [
        { text: 'Breathe In...', duration: 4000 },
        { text: 'Hold...', duration: 4000 },
        { text: 'Breathe Out...', duration: 4000 }
    ];
    
    let step = 0;
    
   function doStep() {
    if (step < steps.length) {
        btn.innerHTML = steps[step].text;
        const dur = steps[step].duration;
        step++;
        setTimeout(doStep, dur);
    } else {
        btn.innerHTML = originalHTML;
    }
}
    doStep();
}

// Animated counter for stats
function animateValue(element, start, end, duration) {
    const range = end - start;
    const increment = range / (duration / 16);
    let current = start;
    
    const timer = setInterval(() => {
        current += increment;
        if (current >= end) {
            current = end;
            clearInterval(timer);
        }
        element.textContent = Math.floor(current) + (element.id.includes('247') ? '' : '+');
    }, 16);
}

// Start counters when visible
const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            document.querySelectorAll('.stat-number').forEach(stat => {
                const value = stat.textContent.replace('+', '');
                if (value === '24/7') return;
                animateValue(stat, 0, parseInt(value), 2000);
            });
            observer.disconnect();
        }
    });
});

observer.observe(document.querySelector('.stats-wrapper'));



// Welcome message for new users
if (!localStorage.getItem('visited')) {
    setTimeout(() => {
        alert('Welcome! Remember, you are not alone. We are here to support you. ðŸ’™');
        localStorage.setItem('visited', 'true');
    }, 2000);
}
</script>

