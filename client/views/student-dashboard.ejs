                                <label for="specializationFilter">Specialization</label>
                                <select id="specializationFilter" onchange="applyCounselorFilters()">
                                    <option value="all">All Specializations</option>
                                    <option>Stress Management</option>
                                    <option>Anxiety</option>
                                    <option>Depression</option>
                                    <option>Placement Stress</option>
                                    <option>Relationship Issues</option>
                                    <option>Academic Pressure</option>
                                    <option>Hostel Adjustment</option>
                                    <option>Self Confidence</option>
                                </select>
                            </div>
                            <div class="filter-control">
                                <label for="availabilityFilter">Availability</label>
                                <select id="availabilityFilter" onchange="applyCounselorFilters()">
                                    <option value="all">Any Availability</option>
                                    <option value="online">Online</option>
                                    <option value="availableNow">Available Now</option>
                                    <option value="busy">Busy</option>
                                    <option value="offline">Offline</option>
                                </select>
                            </div>
                            <div class="filter-control">
                                <label for="ratingFilter">Ratings</label>
                                <select id="ratingFilter" onchange="applyCounselorFilters()">
                                    <option value="all">Any Rating</option>
                                    <option value="5">5 Stars</option>
                                    <option value="4">4+ Stars</option>
                                    <option value="3">3+ Stars</option>
                                </select>
                            </div>
