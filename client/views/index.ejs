</section>

<!-- Categories Section -->
<div class="categories-wrapper">
    <div class="container">
        <div class="section-title">
            <h2>Support Categories</h2>
            <p>Choose the area you need help with</p>
        </div>
        
        <div class="row g-4">
            <div class="col-md-3">
                <div class="category-card">
                    <div class="category-icon" style="background: rgba(107, 140, 255, 0.1);">
                        <i class="fas fa-book-open" style="color: var(--primary-soft);"></i>
                    </div>
                    <span class="category-badge" style="background: rgba(107, 140, 255, 0.1); color: var(--primary-soft);">Academic</span>
                    <p class="text-muted mb-0">Study stress, exam anxiety, time management, academic pressure</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="category-card">
                    <div class="category-icon" style="background: rgba(40, 167, 69, 0.1);">
                        <i class="fas fa-briefcase" style="color: #28A745;"></i>
                    </div>
                    <span class="category-badge" style="background: rgba(40, 167, 69, 0.1); color: #28A745;">Career</span>
                    <p class="text-muted mb-0">Career choices, job search, internship guidance, professional development</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="category-card">
                    <div class="category-icon" style="background: rgba(255, 193, 7, 0.1);">
                        <i class="fas fa-family" style="color: #FFC107;"></i>
                    </div>
                    <span class="category-badge" style="background: rgba(255, 193, 7, 0.1); color: #FFC107;">Family</span>
                    <p class="text-muted mb-0">Family conflicts, relationships, home issues, parental pressure</p>
                </div>
            </div>
            <div class="col-md-3">
                <div class="category-card">
                    <div class="category-icon" style="background: rgba(220, 53, 69, 0.1);">
                        <i class="fas fa-brain" style="color: #DC3545;"></i>
