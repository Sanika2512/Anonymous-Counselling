<script>
let websiteRating = 0;
let currentEditingId = null; // ✅ Track which review is being edited

document.addEventListener('DOMContentLoaded', () => {
    loadWebsiteReviews();
    checkIfAlreadyReviewed();

    document.querySelectorAll('.review-star').forEach(star => {
        star.addEventListener('click', () => {
            websiteRating = parseInt(star.dataset.val);
            document.querySelectorAll('.review-star').forEach((s, i) => {
                s.style.color = i < websiteRating ? '#fbbf24' : '#d1d5db';
                s.style.transform = i < websiteRating ? 'scale(1.2)' : 'scale(1)';
            });
        });
        star.addEventListener('mouseenter', () => {
            const val = parseInt(star.dataset.val);
            document.querySelectorAll('.review-star').forEach((s, i) => {
                s.style.color = i < val ? '#fbbf24' : '#d1d5db';
            });
        });
        star.addEventListener('mouseleave', () => {
            document.querySelectorAll('.review-star').forEach((s, i) => {
                s.style.color = i < websiteRating ? '#fbbf24' : '#d1d5db';
            });
        });
    });
});

async function loadWebsiteReviews() {
    try {
        const res = await fetch('/api/ratings/website');
        const data = await res.json();
        const grid = document.getElementById('reviewsGrid');
        const currentUserId = '<%= locals.currentUser ? locals.currentUser._id.toString() : "" %>';

        if (!data.success || data.reviews.length === 0) {
            grid.innerHTML = `
                <div class="col-12 text-center py-5">
                    <div style="background:linear-gradient(135deg,#f0f7ff,#e6f0fa);border-radius:20px;padding:40px;border:2px dashed #6B8CFF33;">
                        <i class="fas fa-comment-dots" style="font-size:3rem;color:#6B8CFF;opacity:0.5;margin-bottom:15px;display:block;"></i>
                        <p style="color:#6B6B6B;margin:0;font-size:1.1rem;">Be the first to share your experience!</p>
                    </div>
                </div>`;
            return;
        }

        grid.innerHTML = data.reviews.map(r => {
            // ✅ Safe string comparison — both converted to string
            const isAuthor = currentUserId && r.studentId && currentUserId === String(r.studentId);
            
            // ✅ Escape review text safely for use in data attribute
            const safeText = r.reviewText.replace(/"/g, '&quot;');
            
            const authorActions = isAuthor ? `
                <div style="display:flex;gap:8px;margin-top:10px;">
                    <button 
                        data-id="${r._id}" 
                        data-rating="${r.rating}" 
                        data-text="${safeText}"
                        onclick="editReview(this)"
                        style="background:#6B8CFF;color:white;border:none;border-radius:20px;padding:5px 14px;font-size:0.8rem;cursor:pointer;">
                        <i class="fas fa-edit me-1"></i>Edit
                    </button>
                    <button 
                        data-id="${r._id}"
                        onclick="deleteReview(this)"
                        style="background:#ef4444;color:white;border:none;border-radius:20px;padding:5px 14px;font-size:0.8rem;cursor:pointer;">
                        <i class="fas fa-trash me-1"></i>Delete
                    </button>
                </div>` : '';

            return `
            <div class="col-md-6 col-lg-4" id="review-card-${r._id}">
                <div style="background:white;border-radius:24px;padding:28px 24px;border:1px solid rgba(107,140,255,0.15);box-shadow:0 8px 30px rgba(107,140,255,0.08);height:100%;transition:transform 0.3s ease,box-shadow 0.3s ease;"
                     onmouseenter="this.style.transform='translateY(-5px)';this.style.boxShadow='0 15px 40px rgba(107,140,255,0.15)'"
                     onmouseleave="this.style.transform='translateY(0)';this.style.boxShadow='0 8px 30px rgba(107,140,255,0.08)'">
                    <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
                        <div style="width:48px;height:48px;border-radius:50%;background:linear-gradient(135deg,#6B8CFF,#A8D5E5);display:flex;align-items:center;justify-content:center;color:white;flex-shrink:0;">
                            <i class="fas fa-user-secret" style="font-size:1.2rem;"></i>
                        </div>
                        <div>
                            <div style="font-weight:700;color:#1A2B4C;font-size:0.95rem;">${r.username}</div>
                            <div style="color:#fbbf24;font-size:1rem;letter-spacing:1px;">${'★'.repeat(r.rating)}${'☆'.repeat(5 - r.rating)}</div>
                        </div>
                    </div>
                    <div style="background:linear-gradient(135deg,#f8faff,#f0f7ff);border-radius:14px;padding:14px 16px;margin-bottom:14px;border-left:3px solid #6B8CFF;">
                        <p style="color:#475569;line-height:1.7;font-size:0.95rem;margin:0;font-style:italic;">"${r.reviewText}"</p>
                    </div>
                    <div style="color:#94a3b8;font-size:0.78rem;display:flex;align-items:center;gap:5px;">
                        <i class="fas fa-clock"></i>
                        ${new Date(r.date).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'})}
                    </div>
                    ${authorActions}
                </div>
            </div>`;
        }).join('');
    } catch(e) {
        console.error('Load reviews error:', e);
    }
}

// ✅ Now receives the button element directly — no selector guesswork
function editReview(btnEl) {
    const reviewId = btnEl.dataset.id;
    const currentRating = parseInt(btnEl.dataset.rating);
    const currentText = btnEl.dataset.text.replace(/&quot;/g, '"');

    currentEditingId = reviewId; // ✅ Store globally

    websiteRating = currentRating;
    document.getElementById('reviewText').value = currentText;

    document.querySelectorAll('.review-star').forEach((s, i) => {
        s.style.color = i < currentRating ? '#fbbf24' : '#d1d5db';
        s.style.transform = i < currentRating ? 'scale(1.2)' : 'scale(1)';
    });

    // ✅ Update button to show Update mode
    const submitBtn = document.getElementById('reviewSubmitBtn');
    submitBtn.innerHTML = '<i class="fas fa-save me-2"></i>Update Review';
    submitBtn.style.background = 'linear-gradient(135deg,#10b981,#059669)';
    submitBtn.disabled = false;
    submitBtn.style.opacity = '1';

    document.getElementById('reviewAlreadyMsg').style.display = 'none';
    document.getElementById('reviewSuccessMsg').style.display = 'none';

    submitBtn.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

async function deleteReview(btnEl) {
    const reviewId = btnEl.dataset.id;
    if (!confirm('Delete your review?')) return;

    try {
        const res = await fetch(`/api/ratings/website/${reviewId}`, {
            method: 'DELETE',
            credentials: 'same-origin'
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById(`review-card-${reviewId}`)?.remove();
            showReviewToast('Review deleted!', 'success');
            currentEditingId = null;

            // Re-enable submit form
            const submitBtn = document.getElementById('reviewSubmitBtn');
            if (submitBtn) {
                submitBtn.disabled = false;
                submitBtn.style.opacity = '1';
                submitBtn.style.background = 'linear-gradient(135deg,#667eea,#764ba2)';
                submitBtn.innerHTML = '<i class="fas fa-paper-plane me-2"></i>Submit Review';
            }
            document.getElementById('reviewAlreadyMsg').style.display = 'none';
            document.getElementById('reviewText').value = '';
            websiteRating = 0;
            document.querySelectorAll('.review-star').forEach(s => {
                s.style.color = '#d1d5db';
                s.style.transform = 'scale(1)';
            });
        } else {
            showReviewToast(data.message, 'error');
        }
    } catch(e) {
        showReviewToast('Error deleting review', 'error');
    }
}

// ✅ Single unified submit function — handles both create and update
async function submitWebsiteReview() {
    if (!websiteRating) {
        showReviewToast('Please select a star rating first! ⭐', 'error');
        return;
    }
    const reviewText = document.getElementById('reviewText').value.trim();
    if (!reviewText) {
        showReviewToast('Please write a short review!', 'error');
        return;
    }

    const submitBtn = document.getElementById('reviewSubmitBtn');
    const isEditing = !!currentEditingId;
    const origText = submitBtn.innerHTML;

    submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>' + (isEditing ? 'Updating...' : 'Submitting...');
    submitBtn.disabled = true;

    try {
        const url = isEditing ? `/api/ratings/website/${currentEditingId}` : '/api/ratings/website';
        const method = isEditing ? 'PUT' : 'POST';

        const res = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ rating: websiteRating, reviewText })
        });
        const data = await res.json();

        if (data.success) {
            showReviewToast(isEditing ? 'Review updated!' : 'Review submitted!', 'success');

            // Reset form
            document.getElementById('reviewText').value = '';
            websiteRating = 0;
            currentEditingId = null;
            document.querySelectorAll('.review-star').forEach(s => {
                s.style.color = '#d1d5db';
                s.style.transform = 'scale(1)';
            });

            submitBtn.innerHTML = '<i class="fas fa-check me-2"></i>' + (isEditing ? 'Updated!' : 'Submitted!');
            submitBtn.style.background = 'linear-gradient(135deg,#10b981,#059669)';

            setTimeout(() => {
                // After update: lock again (already reviewed); after new submit: lock too
                submitBtn.disabled = true;
                submitBtn.style.opacity = '0.6';
                submitBtn.innerHTML = '<i class="fas fa-check me-2"></i>Already Reviewed';
                document.getElementById('reviewAlreadyMsg').style.display = 'block';
                document.getElementById('reviewSuccessMsg').style.display = isEditing ? 'none' : 'block';
            }, 1500);

            setTimeout(loadWebsiteReviews, 500);
        } else {
            submitBtn.innerHTML = origText;
            submitBtn.disabled = false;
            showReviewToast(data.message || 'Error. Please try again.', 'error');
        }
    } catch(e) {
        submitBtn.innerHTML = origText;
        submitBtn.disabled = false;
        showReviewToast('Server error. Please try again.', 'error');
    }
}

function checkIfAlreadyReviewed() {
    fetch('/api/ratings/website/check', { credentials: 'same-origin' })
        .then(r => { if (!r.ok) return null; return r.json(); })
        .then(data => {
            if (data && data.hasReviewed) {
                const msg = document.getElementById('reviewAlreadyMsg');
                if (msg) msg.style.display = 'block';
                const btn = document.getElementById('reviewSubmitBtn');
                if (btn) {
                    btn.disabled = true;
                    btn.style.opacity = '0.6';
                    btn.innerHTML = '<i class="fas fa-check me-2"></i>Already Reviewed';
                }
            }
        })
        .catch(() => {});
}

function showReviewToast(message, type) {
    const existing = document.getElementById('reviewToast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.id = 'reviewToast';
    toast.style.cssText = `
        position:fixed;bottom:30px;left:50%;transform:translateX(-50%) translateY(80px);
        background:${type === 'error' ? '#ef4444' : '#10b981'};color:white;
        padding:14px 28px;border-radius:50px;font-weight:600;font-size:0.95rem;
        box-shadow:0 10px 30px rgba(0,0,0,0.15);z-index:99999;
        transition:transform 0.3s ease;display:flex;align-items:center;gap:8px;`;
    toast.innerHTML = `<i class="fas fa-${type === 'error' ? 'exclamation-circle' : 'check-circle'}"></i>${message}`;
    document.body.appendChild(toast);
    setTimeout(() => toast.style.transform = 'translateX(-50%) translateY(0)', 10);
    setTimeout(() => {
        toast.style.transform = 'translateX(-50%) translateY(80px)';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}
</script>



<script>
// Mood booster messages
const moodMessages = [
    "You're stronger than you think! 💪",
    "This too shall pass 🌈",
    "Take a deep breath 🌬️",
    "You matter! ❤️",
    "Small steps are still progress 👣",
    "It's okay to not be okay 🌻",
    "You're doing amazing! ✨",
    "Hope is on the way 🌅"
];

let messageIndex = 0;

function showMoodMessage() {
    const messageEl = document.getElementById('moodMessage');
    messageEl.style.opacity = '1';
    messageEl.style.visibility = 'visible';
    
    // Cycle through messages
    messageEl.textContent = moodMessages[messageIndex];
    messageIndex = (messageIndex + 1) % moodMessages.length;
    
    // Hide after 3 seconds
    setTimeout(() => {
        messageEl.style.opacity = '0';
        messageEl.style.visibility = 'hidden';
    }, 3000);
    
    // Play gentle sound
    playGentleSound();
}

function playGentleSound() {
    const audio = new Audio('data:audio/wav;base64,UklGRlwAAABXQVZFZm10IBAAAAABAAEAQB8AAEAfAAABAAgAZGF0YVAAAAA8AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA'); // Silent audio
    audio.volume = 0.1;
    audio.play().catch(e => {});
}

// Breathing exercise
function startBreathing() {
    const btn = document.querySelector('.breathing-btn');
    const originalHTML = btn.innerHTML;
    
    btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';
    
    const steps = [
        { text: 'Breathe In...', duration: 4000 },
        { text: 'Hold...', duration: 4000 },
        { text: 'Breathe Out...', duration: 4000 }
    ];
    
    let step = 0;
    
   function doStep() {
    if (step < steps.length) {
        btn.innerHTML = steps[step].text;
        const dur = steps[step].duration;
        step++;
        setTimeout(doStep, dur);
    } else {
        btn.innerHTML = originalHTML;
    }
}
    doStep();
}

// Animated counter for stats
function animateValue(element, start, end, duration) {
    const range = end - start;
    const increment = range / (duration / 16);
    let current = start;
    
    const timer = setInterval(() => {
        current += increment;
        if (current >= end) {
            current = end;
            clearInterval(timer);
        }
        element.textContent = Math.floor(current) + (element.id.includes('247') ? '' : '+');
    }, 16);
}

// Start counters when visible
const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            document.querySelectorAll('.stat-number').forEach(stat => {
                const value = stat.textContent.replace('+', '');
                if (value === '24/7') return;
                animateValue(stat, 0, parseInt(value), 2000);
            });
            observer.disconnect();
        }
    });
});

observer.observe(document.querySelector('.stats-wrapper'));



// Welcome message for new users
if (!localStorage.getItem('visited')) {
    setTimeout(() => {
        alert('Welcome! Remember, you are not alone. We are here to support you. 💙');
        localStorage.setItem('visited', 'true');
    }, 2000);
}
</script>

