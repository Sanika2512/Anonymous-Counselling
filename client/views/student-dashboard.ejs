<%- include('partials/header') %>

<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">

<style>
/* ===== ROOT VARIABLES ===== */
:root {
  --brand: #4361ee;
  --brand-2: #7b2ff7;
  --brand-light: #e8edff;
  --accent: #06d6a0;
  --accent-warm: #ff6b6b;
  --gold: #fbbf24;
  --surface: rgba(255,255,255,0.72);
  --surface-2: rgba(255,255,255,0.45);
  --border: rgba(67,97,238,0.13);
  --text-primary: #0f1628;
  --text-secondary: #5a6482;
  --text-muted: #9aa3c0;
  --sidebar-bg: linear-gradient(160deg, #0f1628 0%, #1a2550 60%, #0f1628 100%);
  --glow: 0 0 40px rgba(67,97,238,0.18);
  --radius: 20px;
  --radius-sm: 12px;
  --transition: 0.35s cubic-bezier(0.34,1.4,0.64,1);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

body {
  font-family: 'DM Sans', sans-serif;
  background: #f0f2f9;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ===== ANIMATED BACKGROUND ===== */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background:
    radial-gradient(ellipse 900px 700px at 80% -10%, rgba(67,97,238,0.08) 0%, transparent 70%),
    radial-gradient(ellipse 600px 500px at -10% 80%, rgba(123,47,247,0.07) 0%, transparent 70%),
    radial-gradient(ellipse 500px 400px at 50% 110%, rgba(6,214,160,0.05) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* ===== SIDEBAR ===== */
.sidebar {
  background: var(--sidebar-bg);
  border-right: none;
  box-shadow: 4px 0 40px rgba(10,15,40,0.3);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 32px 16px;
  position: sticky;
  top: 0;
  transition: all 0.3s ease;
  z-index: 100;
  overflow: hidden;
}

/* Sidebar inner glow orbs */
.sidebar::before {
  content: '';
  position: absolute;
  top: -60px; left: -60px;
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(67,97,238,0.25) 0%, transparent 70%);
  pointer-events: none;
}

.sidebar::after {
  content: '';
  position: absolute;
  bottom: -40px; right: -40px;
  width: 180px; height: 180px;
  background: radial-gradient(circle, rgba(123,47,247,0.2) 0%, transparent 70%);
  pointer-events: none;
}

.message-dots { display: none !important; }

.user-profile-container {
  width: 100%;
  padding: 0 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  position: relative;
  z-index: 1;
}

/* ===== AVATAR ===== */
.avatar-circle {
  width: 90px;
  height: 90px;
  border-radius: 50%;
  background: linear-gradient(135deg, #4361ee, #7b2ff7);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  position: relative;
  transition: var(--transition);
  border: 3px solid rgba(255,255,255,0.15);
  box-shadow: 0 0 0 6px rgba(67,97,238,0.18), 0 20px 40px rgba(0,0,0,0.35);
}

.avatar-circle::before {
  content: '';
  position: absolute;
  inset: -4px;
  border-radius: 50%;
  background: conic-gradient(from 0deg, #4361ee, #7b2ff7, #06d6a0, #4361ee);
  z-index: -1;
  opacity: 0;
  transition: opacity 0.4s ease;
  animation: spin-slow 3s linear infinite;
}

.avatar-circle:hover::before { opacity: 1; }

@keyframes spin-slow { to { transform: rotate(360deg); } }

.avatar-circle:hover {
  transform: scale(1.08) translateY(-3px);
  box-shadow: 0 0 0 6px rgba(67,97,238,0.35), 0 25px 50px rgba(0,0,0,0.4);
}

.avatar-circle i {
  font-size: 2.8rem;
  color: white;
  transition: transform 0.5s ease;
  filter: drop-shadow(0 2px 8px rgba(0,0,0,0.3));
}

.avatar-circle:hover i { transform: scale(1.1); }

/* ===== USERNAME ===== */
.user-profile-container h5 {
  font-family: 'Sora', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.3px;
  cursor: pointer;
  transition: color 0.25s;
  text-align: center;
}

.user-profile-container h5:hover { color: #a5b4fc; }

/* ===== STUDENT BADGE ===== */
.badge-student {
  background: rgba(67,97,238,0.25);
  color: #a5b4fc;
  padding: 6px 18px;
  border-radius: 50px;
  font-size: 0.82rem;
  font-weight: 600;
  border: 1px solid rgba(165,180,252,0.25);
  cursor: pointer;
  transition: var(--transition);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.badge-student:hover {
  background: rgba(67,97,238,0.5);
  color: #fff;
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(67,97,238,0.3);
}

/* ===== SIDEBAR DIVIDER ===== */
.sidebar-divider {
  width: 100%;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
  margin: 4px 0;
}

/* ===== COUNSELOR STATUS ===== */
.counselor-status-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px 16px;
  border-radius: 50px;
  font-size: 0.85rem;
  font-weight: 600;
  width: 100%;
  cursor: pointer;
  transition: var(--transition);
  gap: 8px;
}

.counselor-online {
  background: rgba(6,214,160,0.15);
  color: #06d6a0;
  border: 1px solid rgba(6,214,160,0.3);
}

.counselor-offline {
  background: rgba(255,255,255,0.07);
  color: rgba(255,255,255,0.5);
  border: 1px solid rgba(255,255,255,0.1);
}

.counselor-status-badge:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(0,0,0,0.2);
}

/* ===== PULSE INDICATOR ===== */
.realtime-indicator {
  width: 10px;
  height: 10px;
  background: #06d6a0;
  border-radius: 50%;
  flex-shrink: 0;
  animation: pulse 2s infinite;
  box-shadow: 0 0 0 3px rgba(6,214,160,0.25);
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 1; box-shadow: 0 0 0 3px rgba(6,214,160,0.25); }
  50% { transform: scale(1.2); opacity: 0.8; box-shadow: 0 0 0 6px rgba(6,214,160,0.1); }
  100% { transform: scale(1); opacity: 1; box-shadow: 0 0 0 3px rgba(6,214,160,0.25); }
}

/* ===== AUTO CHATBOT TEXT ===== */
.auto-chatbot-text {
  color: rgba(255,255,255,0.45);
  font-size: 0.78rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 7px;
  padding: 8px 14px;
  border-radius: 50px;
  width: 100%;
  cursor: pointer;
  transition: var(--transition);
  background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.07);
}

.auto-chatbot-text:hover {
  background: rgba(123,47,247,0.2);
  color: #c4b5fd;
  border-color: rgba(196,181,253,0.3);
  transform: translateY(-2px);
}

.auto-chatbot-text i { color: #7b2ff7; transition: transform 0.3s ease; }
.auto-chatbot-text:hover i { transform: rotate(15deg) scale(1.2); color: #c4b5fd; }

/* ===== WEATHER WIDGET ===== */
.weather-widget {
  background: linear-gradient(135deg, rgba(67,97,238,0.4) 0%, rgba(123,47,247,0.4) 100%);
  border: 1px solid rgba(165,180,252,0.2);
  backdrop-filter: blur(10px);
  color: white;
  padding: 18px 20px;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  cursor: pointer;
  transition: var(--transition);
  box-shadow: 0 8px 24px rgba(0,0,0,0.25);
  position: relative;
  overflow: hidden;
}

.weather-widget::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, transparent 60%);
  pointer-events: none;
}

.weather-widget:hover {
  transform: translateY(-4px) scale(1.02);
  box-shadow: 0 16px 36px rgba(67,97,238,0.35);
  border-color: rgba(165,180,252,0.4);
}

.weather-widget .temp {
  font-family: 'Sora', sans-serif;
  font-size: 2rem;
  font-weight: 800;
  line-height: 1;
  letter-spacing: -1px;
}

.weather-widget .condition {
  font-size: 0.8rem;
  opacity: 0.8;
  margin-top: 4px;
  font-weight: 400;
}

.weather-widget i {
  font-size: 2.4rem;
  opacity: 0.9;
  filter: drop-shadow(0 2px 8px rgba(255,215,0,0.4));
  transition: transform 0.5s ease;
}

.weather-widget:hover i { transform: rotate(20deg) scale(1.15); }

/* ===== MAIN CONTENT ===== */
.main-content {
  padding: 36px 40px;
  position: relative;
  z-index: 1;
}

/* ===== WELCOME SECTION ===== */
.welcome-section {
  background: linear-gradient(130deg, #4361ee 0%, #7b2ff7 50%, #3a0ca3 100%);
  color: white;
  padding: 36px 40px;
  border-radius: 28px;
  margin-bottom: 28px;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(67,97,238,0.35);
  transition: var(--transition);
}

.welcome-section::before {
  content: '';
  position: absolute;
  top: -80px; right: -60px;
  width: 280px; height: 280px;
  background: radial-gradient(circle, rgba(255,255,255,0.12) 0%, transparent 70%);
  pointer-events: none;
}

.welcome-section::after {
  content: '';
  position: absolute;
  bottom: -60px; left: 40%;
  width: 200px; height: 200px;
  background: radial-gradient(circle, rgba(6,214,160,0.15) 0%, transparent 70%);
  pointer-events: none;
}

.welcome-section:hover { transform: translateY(-4px); box-shadow: 0 28px 70px rgba(67,97,238,0.45); }

.welcome-tag {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  background: rgba(255,255,255,0.15);
  border: 1px solid rgba(255,255,255,0.2);
  padding: 5px 14px;
  border-radius: 50px;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.8px;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.welcome-tag i { font-size: 0.7rem; color: #06d6a0; }

.welcome-section h1 {
  font-family: 'Sora', sans-serif;
  font-size: 2rem;
  font-weight: 800;
  margin-bottom: 8px;
  letter-spacing: -0.5px;
  position: relative;
  z-index: 1;
}

.welcome-section p {
  font-size: 0.95rem;
  opacity: 0.82;
  position: relative;
  z-index: 1;
}

.welcome-stats {
  display: flex;
  gap: 20px;
  margin-top: 24px;
  position: relative;
  z-index: 1;
  flex-wrap: wrap;
}

.welcome-stat {
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 14px;
  padding: 12px 20px;
  backdrop-filter: blur(4px);
  transition: var(--transition);
}

.welcome-stat:hover {
  background: rgba(255,255,255,0.2);
  transform: translateY(-2px);
}

.welcome-stat .stat-num {
  font-family: 'Sora', sans-serif;
  font-size: 1.4rem;
  font-weight: 800;
  line-height: 1;
}

.welcome-stat .stat-label {
  font-size: 0.75rem;
  opacity: 0.75;
  margin-top: 3px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

/* ===== ACTION BUTTONS ===== */
.action-buttons {
  display: flex;
  gap: 14px;
  margin-bottom: 32px;
}

.btn-chatbot {
  background: linear-gradient(135deg, #7b2ff7, #4361ee);
  border: none;
  padding: 16px 30px;
  border-radius: var(--radius-sm);
  color: white;
  font-family: 'Sora', sans-serif;
  font-weight: 600;
  font-size: 0.95rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  flex: 1;
  cursor: pointer;
  transition: var(--transition);
  box-shadow: 0 10px 30px rgba(123,47,247,0.3);
  position: relative;
  overflow: hidden;
  letter-spacing: 0.2px;
}

.btn-chatbot::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 60%);
  pointer-events: none;
}

.btn-chatbot::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, #06d6a0, #4361ee);
  opacity: 0;
  transition: opacity 0.35s ease;
}

.btn-chatbot:hover { transform: translateY(-4px) scale(1.02); box-shadow: 0 20px 40px rgba(123,47,247,0.45); }
.btn-chatbot:hover::after { opacity: 1; }
.btn-chatbot span, .btn-chatbot i { position: relative; z-index: 1; }

.btn-refresh {
  background: white;
  border: 2px solid #e5e9f8;
  padding: 16px 22px;
  border-radius: var(--radius-sm);
  color: var(--text-secondary);
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  cursor: pointer;
  transition: var(--transition);
  box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  min-width: 58px;
}

.btn-refresh:hover {
  border-color: var(--brand);
  color: var(--brand);
  transform: translateY(-3px);
  box-shadow: 0 10px 24px rgba(67,97,238,0.18);
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ===== SECTION TITLE ===== */
.section-title {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 22px;
  position: relative;
}

.section-title-icon {
  width: 44px;
  height: 44px;
  background: linear-gradient(135deg, #eef1ff, #dde3ff);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 12px rgba(67,97,238,0.12);
  flex-shrink: 0;
}

.section-title-icon i { color: var(--brand); font-size: 1.15rem; }

.section-title h3 {
  font-family: 'Sora', sans-serif;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0;
  letter-spacing: -0.3px;
}

.section-title-line {
  flex: 1;
  height: 2px;
  background: linear-gradient(90deg, rgba(67,97,238,0.15), transparent);
  border-radius: 2px;
}

/* ===== SEARCH BAR ===== */
.search-wrapper {
  background: white;
  border: 2px solid #eaeef8;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  padding: 0 18px;
  gap: 12px;
  margin-bottom: 28px;
  transition: var(--transition);
  box-shadow: 0 4px 16px rgba(0,0,0,0.04);
}

.search-wrapper:focus-within {
  border-color: var(--brand);
  box-shadow: 0 4px 24px rgba(67,97,238,0.15);
}

.search-wrapper i { color: var(--text-muted); transition: color 0.25s; font-size: 1rem; }
.search-wrapper:focus-within i { color: var(--brand); }

#searchCounselors {
  border: none;
  outline: none;
  flex: 1;
  padding: 16px 0;
  font-family: 'DM Sans', sans-serif;
  font-size: 0.95rem;
  color: var(--text-primary);
  background: transparent;
}

#searchCounselors::placeholder { color: var(--text-muted); }

.counselor-filter-panel {
  background: rgba(255,255,255,0.86);
  border: 1.5px solid #e4e9f8;
  border-radius: 18px;
  padding: 18px;
  margin-bottom: 24px;
  box-shadow: 0 10px 30px rgba(67,97,238,0.08);
}

.filter-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(160px, 1fr));
  gap: 12px;
}

.filter-control label {
  display: block;
  color: var(--text-secondary);
  font-size: 0.78rem;
  font-weight: 700;
  margin-bottom: 6px;
}

.filter-control select {
  width: 100%;
  border: 1.5px solid #e2e8f0;
  border-radius: 12px;
  padding: 11px 12px;
  color: var(--text-primary);
  background: white;
  font-weight: 600;
  outline: none;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.filter-control select:focus {
  border-color: var(--brand);
  box-shadow: 0 0 0 4px rgba(67,97,238,0.1);
}

.filter-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin-top: 14px;
}

.clear-filters-btn, .load-more-btn {
  border: 1.5px solid #dfe6fb;
  background: white;
  color: var(--brand);
  border-radius: 999px;
  padding: 10px 16px;
  font-weight: 800;
  cursor: pointer;
  transition: all 0.2s ease;
}

.clear-filters-btn:hover, .load-more-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 10px 20px rgba(67,97,238,0.12);
}

.results-meta {
  color: var(--text-muted);
  font-size: 0.86rem;
  font-weight: 700;
}

.counselor-skeleton {
  height: 315px;
  border-radius: 24px;
  background: linear-gradient(90deg, #f3f6ff 25%, #e9eefb 37%, #f3f6ff 63%);
  background-size: 400% 100%;
  animation: skeletonShimmer 1.3s ease infinite;
}

@keyframes skeletonShimmer {
  0% { background-position: 100% 0; }
  100% { background-position: 0 0; }
}

/* ===== COUNSELORS GRID ===== */
#counselorsGrid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 22px;
}

/* Reset bootstrap row */
#counselorsGrid.row { margin: 0; }
#counselorsGrid .col-md-6, #counselorsGrid .col-lg-4 { padding: 0; width: auto; flex: none; }

/* ===== COUNSELOR CARD ===== */
#counselorsGrid .card {
  background: white;
  border: 1.5px solid #eaeef8;
  border-radius: 24px;
  box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  transition: all 0.4s cubic-bezier(0.34, 1.4, 0.64, 1);
  overflow: hidden;
  cursor: pointer;
  position: relative;
  height: 100%;
}

#counselorsGrid .card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 4px;
  background: linear-gradient(90deg, #4361ee, #7b2ff7, #06d6a0);
  opacity: 0;
  transition: opacity 0.35s ease;
}

#counselorsGrid .card:hover::before { opacity: 1; }

#counselorsGrid .card:hover {
  border-color: rgba(67,97,238,0.25);
  box-shadow: 0 20px 50px rgba(67,97,238,0.18);
  transform: translateY(-10px) scale(1.02);
}

#counselorsGrid .card-body {
  padding: 28px 22px 24px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

/* ===== AVATAR WRAPPER ===== */
.avatar-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 16px;
}

#counselorsGrid .rounded-circle {
  width: 88px;
  height: 88px;
  border: 4px solid white;
  box-shadow: 0 8px 24px rgba(0,0,0,0.12);
  object-fit: cover;
  border-radius: 50%;
  transition: all 0.4s ease;
}

#counselorsGrid .card:hover .rounded-circle {
  box-shadow: 0 12px 32px rgba(67,97,238,0.25);
  transform: scale(1.05);
}

/* ===== COUNSELOR NAME ===== */
#counselorsGrid h5 {
  font-family: 'Sora', sans-serif;
  font-size: 1.08rem;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: -0.2px;
  margin-bottom: 10px;
}

/* ===== SPECIALIZATION BADGE ===== */
#counselorsGrid .specialization-badge {
  color: var(--brand);
  font-size: 0.8rem;
  font-weight: 600;
  background: linear-gradient(135deg, #eef1ff, #e3e8ff);
  padding: 6px 16px;
  border-radius: 50px;
  display: inline-block;
  margin-bottom: 8px;
  border: 1px solid rgba(67,97,238,0.15);
  transition: all 0.3s ease;
}

#counselorsGrid .card:hover .specialization-badge {
  background: linear-gradient(135deg, #4361ee, #7b2ff7);
  color: white;
  border-color: transparent;
}

/* ===== EDUCATION ===== */
#counselorsGrid .education-text {
  color: var(--text-muted);
  font-size: 0.82rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  margin-bottom: 12px;
}

#counselorsGrid .education-text i { color: var(--brand); opacity: 0.7; }

/* ===== RATING ===== */
.counselor-rating {
  margin: 10px 0 18px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 3px;
}

.counselor-rating .fa-star.text-warning,
.counselor-rating .fa-star-half-alt.text-warning { color: var(--gold) !important; font-size: 15px; }
.counselor-rating .fa-star.text-muted,
.counselor-rating .far.fa-star { color: #e5e7eb !important; font-size: 15px; }

/* ===== STATUS DOT ===== */
.counselor-status-dot {
  position: absolute;
  bottom: 5px; right: 5px;
  width: 16px; height: 16px;
  border-radius: 50%;
  border: 3px solid white;
  box-shadow: 0 2px 6px rgba(0,0,0,0.15);
}

.dot-online { background: #06d6a0; animation: pulse 2s infinite; }
.dot-offline { background: #cbd5e1; }

/* ===== ONLINE LABEL ===== */
.online-status-label {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 0.75rem;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 50px;
  margin-bottom: 4px;
  letter-spacing: 0.3px;
}

.label-online {
  background: rgba(6,214,160,0.1);
  color: #059669;
  border: 1px solid rgba(6,214,160,0.3);
}

.label-offline {
  background: rgba(203,213,225,0.2);
  color: #94a3b8;
  border: 1px solid rgba(203,213,225,0.4);
}

/* ===== CHAT BUTTON ===== */
#counselorsGrid .btn-chat {
  background: linear-gradient(135deg, #4361ee, #7b2ff7);
  border: none;
  padding: 13px 20px;
  border-radius: 50px;
  font-size: 0.88rem;
  font-weight: 600;
  font-family: 'Sora', sans-serif;
  color: white;
  box-shadow: 0 8px 20px rgba(67,97,238,0.25);
  cursor: pointer;
  transition: all 0.35s ease;
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  letter-spacing: 0.2px;
  position: relative;
  overflow: hidden;
  margin-top: auto;
}

#counselorsGrid .btn-chat::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15) 0%, transparent 60%);
}

#counselorsGrid .btn-chat:hover {
  transform: scale(1.04) translateY(-2px);
  box-shadow: 0 16px 36px rgba(67,97,238,0.4);
}

.btn-chat-offline {
  background: linear-gradient(135deg, #94a3b8, #64748b) !important;
  box-shadow: 0 8px 20px rgba(100,116,139,0.2) !important;
}

.counselor-offline-card { opacity: 0.88; }
.counselor-offline-card:hover { opacity: 1; }

/* ===== EMPTY STATE ===== */
.empty-state {
  text-align: center;
  padding: 70px 30px;
  background: white;
  border-radius: 24px;
  width: 100%;
  border: 2px dashed #e2e8f0;
  grid-column: 1 / -1;
}

.empty-state-icon {
  width: 80px;
  height: 80px;
  background: linear-gradient(135deg, #eef1ff, #dde3ff);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20px;
}

.empty-state-icon i { font-size: 2rem; color: var(--brand); opacity: 0.6; }

/* ===== TOAST ===== */
.toast-notification {
  position: fixed;
  bottom: 28px;
  right: 28px;
  background: white;
  border-radius: 16px;
  padding: 16px 24px;
  box-shadow: 0 16px 48px rgba(0,0,0,0.15);
  display: flex;
  align-items: center;
  gap: 14px;
  transform: translateX(120%) translateY(10px);
  transition: transform 0.4s cubic-bezier(0.34,1.4,0.64,1), opacity 0.4s ease;
  z-index: 9999;
  border-left: 4px solid var(--brand);
  max-width: 340px;
}

.toast-notification.show { transform: translateX(0) translateY(0); }
.toast-notification i { font-size: 1.4rem; color: var(--brand); flex-shrink: 0; }
.toast-notification .toast-title { font-family: 'Sora', sans-serif; font-weight: 700; color: var(--text-primary); margin-bottom: 3px; font-size: 0.9rem; }
.toast-notification .toast-message { color: var(--text-secondary); font-size: 0.82rem; }

/* ===== LOADING ===== */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(240,242,249,0.75);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.loading-overlay.show { opacity: 1; visibility: visible; }

.loading-spinner {
  width: 52px;
  height: 52px;
  border: 4px solid #e0e7ff;
  border-top-color: var(--brand);
  border-right-color: #7b2ff7;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  box-shadow: 0 8px 24px rgba(67,97,238,0.2);
}

/* ===== RATING MODAL ===== */
#ratingModal {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 99999;
  align-items: center;
  justify-content: center;
}

#ratingModal.show { display: flex; }

.rating-overlay {
  position: absolute;
  inset: 0;
  background: rgba(15,22,40,0.55);
  backdrop-filter: blur(6px);
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

.rating-box {
  position: relative;
  background: white;
  border-radius: 28px;
  padding: 40px 44px 36px;
  width: 400px;
  max-width: 95vw;
  text-align: center;
  box-shadow: 0 40px 80px rgba(0,0,0,0.25);
  animation: slideUp 0.4s cubic-bezier(0.34,1.56,0.64,1);
  z-index: 1;
  border: 1.5px solid #eaeef8;
}

@keyframes slideUp {
  from { transform: translateY(50px) scale(0.95); opacity: 0; }
  to { transform: translateY(0) scale(1); opacity: 1; }
}

.rating-box h4 {
  font-family: 'Sora', sans-serif;
  font-size: 1.35rem;
  font-weight: 800;
  color: var(--text-primary);
  margin-bottom: 8px;
  letter-spacing: -0.3px;
}

.rating-box p { color: var(--text-secondary); font-size: 0.93rem; margin-bottom: 24px; }

.star-row {
  display: flex;
  justify-content: center;
  gap: 10px;
  margin-bottom: 28px;
}

.star-row i {
  font-size: 2.4rem;
  color: #e5e7eb;
  cursor: pointer;
  transition: color 0.15s ease, transform 0.2s cubic-bezier(0.34,1.56,0.64,1);
}

.star-row i.active, .star-row i:hover { color: var(--gold); transform: scale(1.2) rotate(-5deg); }

.rating-submit-btn {
  background: linear-gradient(135deg, #4361ee, #7b2ff7);
  color: white;
  border: none;
  border-radius: 50px;
  padding: 14px 40px;
  font-family: 'Sora', sans-serif;
  font-size: 0.95rem;
  font-weight: 700;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 10px 28px rgba(67,97,238,0.3);
  width: 100%;
}

.rating-submit-btn:hover {
  transform: translateY(-3px);
  box-shadow: 0 18px 40px rgba(67,97,238,0.45);
}

.rating-skip { margin-top: 16px; font-size: 0.83rem; color: var(--text-muted); cursor: pointer; display: inline-block; transition: color 0.2s; }
.rating-skip:hover { color: var(--text-secondary); }

.rating-close-btn {
  position: absolute;
  top: 16px; right: 20px;
  background: #f0f4ff;
  border: none;
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.2s;
  font-size: 0.9rem;
}

.rating-close-btn:hover { background: #e0e7ff; color: var(--text-primary); }

.rating-success { display: none; flex-direction: column; align-items: center; gap: 12px; }
.rating-success i { font-size: 3.5rem; color: #06d6a0; animation: popIn 0.4s cubic-bezier(0.34,1.56,0.64,1); }

@keyframes popIn { from { transform: scale(0) rotate(-30deg); } to { transform: scale(1) rotate(0deg); } }

/* ===== SCROLLBAR ===== */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #d1d5e8; border-radius: 8px; }
::-webkit-scrollbar-thumb:hover { background: var(--brand); }

/* ===== RESPONSIVE ===== */
@media (max-width: 991px) {
  .main-content { padding: 24px 20px; }
  .welcome-section { padding: 28px 24px; }
  .welcome-section h1 { font-size: 1.5rem; }
  #counselorsGrid { grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); }
  .filter-grid { grid-template-columns: repeat(2, minmax(150px, 1fr)); }
}

@media (max-width: 767px) {
  #counselorsGrid { grid-template-columns: 1fr; }
  .welcome-stats { flex-direction: column; gap: 12px; }
  .action-buttons { flex-direction: column; }
  .btn-refresh { width: 100%; }
  .filter-grid { grid-template-columns: 1fr; }
  .filter-actions { flex-direction: column; align-items: stretch; }
}

/* ===== ENTRANCE ANIMATIONS ===== */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(24px); }
  to { opacity: 1; transform: translateY(0); }
}

.welcome-section { animation: fadeUp 0.6s ease forwards; }
.action-buttons { animation: fadeUp 0.6s 0.1s ease both; }
.section-title { animation: fadeUp 0.6s 0.2s ease both; }
.search-wrapper { animation: fadeUp 0.6s 0.25s ease both; }

/* ===== RECOMMENDED RESOURCES ===== */
.recommendations-panel {
  background: rgba(255,255,255,0.92);
  border: 1px solid rgba(67,97,238,0.14);
  border-radius: 18px;
  padding: 24px;
  margin-bottom: 32px;
  box-shadow: 0 12px 34px rgba(15,22,40,0.08);
}

.recommendations-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18px;
  margin-bottom: 18px;
}

.recommendations-title {
  display: flex;
  align-items: center;
  gap: 12px;
}

.recommendations-title i {
  width: 42px;
  height: 42px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 12px;
  color: #4361ee;
  background: #eef1ff;
}

.recommendations-title h3 {
  font-family: 'Sora', sans-serif;
  font-size: 1.14rem;
  font-weight: 700;
  margin: 0;
  color: var(--text-primary);
}

.recommendations-title p {
  margin: 3px 0 0;
  color: var(--text-secondary);
  font-size: 0.88rem;
}

.recommendations-disclaimer {
  color: #64748b;
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 12px;
  padding: 10px 12px;
  font-size: 0.78rem;
  line-height: 1.45;
  max-width: 360px;
}

.recommendations-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  gap: 14px;
}

.resource-card {
  background: #fff;
  border: 1px solid #e7ebf6;
  border-radius: 14px;
  padding: 16px;
  min-height: 190px;
  display: flex;
  flex-direction: column;
  gap: 10px;
  transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
}

.resource-card:hover {
  transform: translateY(-4px);
  border-color: rgba(67,97,238,0.28);
  box-shadow: 0 12px 28px rgba(67,97,238,0.12);
}

.resource-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.resource-icon {
  width: 38px;
  height: 38px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  background: linear-gradient(135deg, #4361ee, #06d6a0);
  flex-shrink: 0;
}

.resource-type {
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  color: #4361ee;
  background: #eef1ff;
  border-radius: 999px;
  padding: 5px 10px;
}

.resource-card h4 {
  font-family: 'Sora', sans-serif;
  font-size: 0.98rem;
  font-weight: 700;
  line-height: 1.3;
  color: var(--text-primary);
  margin: 0;
}

.resource-card p {
  color: var(--text-secondary);
  font-size: 0.86rem;
  line-height: 1.45;
  margin: 0;
}

.resource-category {
  color: #0f766e;
  background: #ecfdf5;
  border-radius: 999px;
  padding: 5px 10px;
  font-size: 0.74rem;
  font-weight: 700;
  width: fit-content;
}

.resource-action {
  margin-top: auto;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: none;
  border-radius: 10px;
  background: #0f1628;
  color: #fff;
  padding: 10px 12px;
  font-weight: 700;
  text-decoration: none;
  cursor: pointer;
}

.resource-action:hover {
  color: #fff;
  background: #4361ee;
}

.recommendations-state {
  grid-column: 1 / -1;
  text-align: center;
  padding: 30px 16px;
  color: var(--text-secondary);
  border: 1px dashed #dbe3f0;
  border-radius: 14px;
  background: #fbfdff;
}

.recommendation-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 14px;
}

.recommendation-chip {
  color: #334155;
  background: #f1f5f9;
  border: 1px solid #e2e8f0;
  border-radius: 999px;
  padding: 6px 10px;
  font-size: 0.78rem;
  font-weight: 700;
}

@media (max-width: 991px) {
  .recommendations-header {
    flex-direction: column;
  }
  .recommendations-disclaimer {
    max-width: none;
    width: 100%;
  }
}

@media (max-width: 575px) {
  .recommendations-panel {
    padding: 18px;
    border-radius: 14px;
  }
  .recommendations-grid {
    grid-template-columns: 1fr;
  }
  .action-buttons {
    flex-direction: column;
  }
}

