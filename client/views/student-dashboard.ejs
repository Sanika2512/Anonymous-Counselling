                        <div class="filter-actions">
                            <div class="filter-control" style="min-width:220px;">
                                <label for="sortFilter">Sort by</label>
                                <select id="sortFilter" onchange="applyCounselorFilters()">
                                    <option value="online">Online First</option>
                                    <option value="highestRated">Highest Rated</option>
                                    <option value="lowestRated">Lowest Rated</option>
                                    <option value="mostExperienced">Most Experienced</option>
                                    <option value="newestAdded">Newest Added</option>
                                </select>
                            </div>
                            <span class="results-meta" id="counselorResultsMeta">Loading counselors...</span>
                            <button class="clear-filters-btn" type="button" onclick="clearCounselorFilters()">
                                <i class="fas fa-filter-circle-xmark me-1"></i>Clear Filters
                            </button>
                        </div>
                    </div>

                    <!-- Grid -->
                    <div id="counselorsGrid">
                        <div style="grid-column:1/-1; text-align:center; padding:60px 0;">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading…</span>
                            </div>
