    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script src="/js/RatingService.js"></script>
<script src="/js/StarRating.js"></script>
<script src="/js/RatingModal.js"></script>
<script>
let socket;
let allCounselors = [];
let filteredCounselors = [];
let searchTimeout;
let memoizedFilterKey = '';
let memoizedFilterResult = [];

let selectedRating = 0;
let ratingShownThisSession = false;

function showLoading() { document.getElementById('loadingOverlay').classList.add('show'); }
function hideLoading() { document.getElementById('loadingOverlay').classList.remove('show'); }

function showToast(title, message, type = 'info') {
    const toast = document.getElementById('toastNotification');
    document.getElementById('toastTitle').textContent = title;
    document.getElementById('toastMessage').textContent = message;
    const icon = toast.querySelector('i');
    const colors = { success:'#06d6a0', error:'#ff6b6b', info:'#4361ee' };
    const icons = { success:'check-circle', error:'exclamation-circle', info:'info-circle' };
    icon.className = `fas fa-${icons[type]||'info-circle'}`;
    icon.style.color = colors[type] || colors.info;
    toast.style.borderLeftColor = colors[type] || colors.info;
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3000);
}

function escapeHTML(value) {
    return String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
    }[char]));
}

function renderRecommendationCards(items = []) {
    const grid = document.getElementById('recommendationsGrid');
    if (!grid) return;

    if (!items.length) {
        grid.innerHTML = `
            <div class="recommendations-state">
                <i class="fas fa-leaf mb-2 d-block" style="font-size:1.6rem;color:#94a3b8;"></i>
                No recommendations yet. Start a chat or submit an issue to receive personalized support.
            </div>`;
        return;
    }

    grid.innerHTML = items.map(item => {
        const hasUrl = item.url && /^https?:\/\//i.test(item.url);
        const button = hasUrl
            ? `<a class="resource-action" href="${escapeHTML(item.url)}" target="_blank" rel="noopener noreferrer">
                   <i class="fas fa-arrow-up-right-from-square"></i>Open
               </a>`
            : `<button class="resource-action" type="button" onclick="showToast('Wellness Tip', '${escapeHTML(item.action || item.description).replace(/'/g, "\\'")}', 'info')">
                   <i class="fas fa-eye"></i>View
               </button>`;

        return `
            <article class="resource-card">
                <div class="resource-card-top">
                    <span class="resource-icon"><i class="fas ${escapeHTML(item.icon || 'fa-leaf')}"></i></span>
                    <span class="resource-type">${escapeHTML(item.type || 'tip')}</span>
                </div>
                <span class="resource-category">${escapeHTML(item.category || 'Wellness')}</span>
                <h4>${escapeHTML(item.title)}</h4>
                <p>${escapeHTML(item.description)}</p>
                <p><strong>Try:</strong> ${escapeHTML(item.action)}</p>
                ${button}
            </article>`;
    }).join('');
}

function renderRecommendationChips(categories = []) {
    const chips = document.getElementById('recommendationChips');
    if (!chips) return;
    chips.innerHTML = categories.map(category => `
        <span class="recommendation-chip">
            <i class="fas ${escapeHTML(category.icon || 'fa-leaf')} me-1"></i>${escapeHTML(category.label)}
        </span>
    `).join('');
}

async function loadDashboardRecommendations(silent = false) {
    const grid = document.getElementById('recommendationsGrid');
    if (!grid) return;
    if (!silent) {
        grid.innerHTML = `<div class="recommendations-state"><i class="fas fa-spinner fa-spin me-2"></i>Loading recommendations...</div>`;
    }

    try {
        const res = await fetch('/api/recommendations/dashboard', { credentials: 'same-origin' });
        const data = await res.json();
        if (!data.success) throw new Error(data.message || 'Recommendation request failed');
        document.getElementById('recommendationsDisclaimer').textContent = data.disclaimer;
        renderRecommendationChips(data.detectedCategories || []);
        renderRecommendationCards(data.recommendations || []);
    } catch (err) {
        grid.innerHTML = `
            <div class="recommendations-state">
                <i class="fas fa-triangle-exclamation mb-2 d-block" style="font-size:1.5rem;color:#ff6b6b;"></i>
                Recommendations are temporarily unavailable. Your counseling workflow is still working.
            </div>`;
        if (!silent) showToast('Resources', 'Could not load recommendations right now.', 'error');
    }
}

/* ===== RATING ===== */
document.querySelectorAll('#starRow i').forEach(star => {
    star.addEventListener('click', () => {
        selectedRating = parseInt(star.dataset.val);
        document.querySelectorAll('#starRow i').forEach((s, idx) => s.classList.toggle('active', idx < selectedRating));
    });
    star.addEventListener('mouseenter', () => {
        const val = parseInt(star.dataset.val);
        document.querySelectorAll('#starRow i').forEach((s, idx) => s.style.color = idx < val ? '#fbbf24' : '#e5e7eb');
    });
    star.addEventListener('mouseleave', () => {
        document.querySelectorAll('#starRow i').forEach((s, idx) => s.style.color = idx < selectedRating ? '#fbbf24' : '#e5e7eb');
    });
});

async function maybeShowRatingModal(counselorId, counselorName, messageCount) {
    if (ratingShownThisSession) return;
    if (messageCount < 10) return;
    try {
        const res = await fetch(`/api/ratings/check/${counselorId}`, { credentials: 'same-origin' });
        const data = await res.json();
        if (data.hasRated) return;
    } catch(e) { return; }
    ratingShownThisSession = true;
    openRatingModal(counselorId, counselorName);
}

function openRatingModal(counselorId, counselorName) {
    selectedRating = 0;
    document.querySelectorAll('#starRow i').forEach(s => { s.classList.remove('active'); s.style.color = '#e5e7eb'; });
    document.getElementById('ratingForm').style.display = 'block';
    document.getElementById('ratingSuccess').style.display = 'none';
    document.getElementById('ratingCounselorName').textContent = `How was your session with ${counselorName}?`;
    const modal = document.getElementById('ratingModal');
    modal.dataset.counselorId = counselorId;
    modal.dataset.counselorName = counselorName;
    modal.classList.add('show');
}

function closeRatingModal() { document.getElementById('ratingModal').classList.remove('show'); }

async function submitCounselorRating() {
    if (!selectedRating) { showToast('Select Stars', 'Please select a star rating first.', 'error'); return; }
    const modal = document.getElementById('ratingModal');
    const counselorId = modal.dataset.counselorId;
    try {
        const res = await fetch('/api/ratings/counselor', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ counselorId, rating: selectedRating })
        });
        const data = await res.json();
        if (data.success) {
            document.getElementById('ratingForm').style.display = 'none';
            document.getElementById('ratingSuccess').style.display = 'flex';
            updateCardRating(counselorId, data.avgRating);
            setTimeout(closeRatingModal, 2200);
        } else { showToast('Error', data.message || 'Could not submit rating.', 'error'); }
    } catch(e) { showToast('Error', 'Server error. Please try again.', 'error'); }
}

function updateCardRating(counselorId, newAvg) {
    const card = document.querySelector(`[data-counselor-id="${counselorId}"] .counselor-rating`);
    if (card) card.innerHTML = generateStars(newAvg);
    const c = allCounselors.find(x => String(x._id) === String(counselorId));
    if (c) c.rating = newAvg;
}

/* ===== SOCKET ===== */

document.addEventListener('DOMContentLoaded', function() {
    // ✅ Always hide loading overlay on page load (catches stuck state from startChat)
    hideLoading();

    initializeSocket();
    checkCounselorStatus();
    loadDashboardRecommendations();
    setInterval(checkCounselorStatus, 10000);
    observeCards();

    // Rating trigger on return
    const chatId = sessionStorage.getItem('currentChatId');
    const counselorId = sessionStorage.getItem('currentCounselorId');
    const counselorName = sessionStorage.getItem('currentCounselorName');
    const count = parseInt(sessionStorage.getItem('studentMsgCount') || '0');
    if (chatId && counselorId && count >= 10) {
        setTimeout(() => maybeShowRatingModal(counselorId, counselorName || 'your counselor', count), 1500);
    }
});
window.addEventListener('pageshow', function(event) {
    // event.persisted = true means page was restored from bfcache (Back button)
    if (event.persisted) {
        hideLoading(); // ✅ Clear any stuck loading overlay
        checkCounselorStatus(); // ✅ Reload counselors fresh
    }
});

function initializeSocket() {
    socket = io({ auth: { userId: "<%= user._id %>", role: "student" } });

    socket.on('connect', () => {
        if (typeof currentIssueId !== 'undefined' && currentIssueId) socket.emit('join-chat', currentIssueId);
    });

    socket.on("newMessage", (msg) => {
        if (msg.chatId !== currentIssueId) { loadConversations(); return; }
        if (!selectedIssue) return;
        selectedIssue.messages = selectedIssue.messages || [];
        const exists = selectedIssue.messages.some(m => String(m._id) === String(msg._id));
        if (!exists) {
            selectedIssue.messages.push(msg);
            displayMessages(selectedIssue.messages, selectedIssue);
            const container = document.getElementById('chatMessages');
            container.scrollTop = container.scrollHeight;
        }
        loadConversations();
    });

    socket.on('user-status-change', (data) => {
        if (data.role === 'counselor') { checkCounselorStatus(); showToast('Status Update', 'Counselor status changed', 'info'); }
    });

    socket.on("counselorProfileUpdated", () => {
        checkCounselorStatus();
        showToast('Profile Updated', 'Counselor information has been updated', 'info');
    });

    socket.on("recommendations-refresh", () => {
        loadDashboardRecommendations(true);
    });

    socket.on("online-users", async (users) => {
        const el = document.getElementById("onlineCounselorCount");
        if (el) el.innerText = users.length;
        document.querySelectorAll("#counselorsGrid .card").forEach(card => {
            const dot = card.querySelector(".realtime-indicator");
            const counselorId = card.getAttribute("data-id");
            if (dot) dot.style.display = users.includes(counselorId) ? "inline-block" : "none";
        });
        try {
            const response = await fetch("/api/counselors/online");
            const onlineCounselors = await response.json();
            updateCounselorCards(onlineCounselors);
        } catch(err) { console.error("Error fetching online counselors:", err); }
    });
}
function generateStars(rating) {
    let stars = '';
    const full = Math.floor(rating);
    const half = rating % 1 >= 0.5;
    for (let i = 1; i <= 5; i++) {
        if (i <= full) stars += '<i class="fas fa-star text-warning"></i>';
        else if (i === full + 1 && half) stars += '<i class="fas fa-star-half-alt text-warning"></i>';
        else stars += '<i class="far fa-star text-muted"></i>';
    }
    return stars;
}

function updateCounselorCards(onlineCounselors) { /* counselor list is refreshed and re-filtered in one render pass */ }

const DEFAULT_FILTERS = Object.freeze({
    education: "all",
    specialization: "all",
    availability: "all",
    rating: "all",
    search: "",
    sortBy: "online"
});

let filters = { ...DEFAULT_FILTERS };
let counselorPage = 1;
let counselorHasMore = false;
let counselorLoading = false;
let counselorFetchToken = 0;
let counselorRatingModal;

const COUNSELOR_FETCH_LIMIT = 50;
const BUSY_ISSUE_LIMIT = 5;

const filterControls = Object.freeze({
    education: "educationFilter",
    specialization: "specializationFilter",
    availability: "availabilityFilter",
    rating: "ratingFilter",
    sortBy: "sortFilter",
    search: "searchCounselors"
});

const normalizeText = (value) => String(value ?? "").trim().toLowerCase();
const normalizeNumber = (value, fallback = 0) => {
    const number = Number(value);
    return Number.isFinite(number) ? number : fallback;
};

function debounce(callback, wait = 300) {
    return function debouncedCallback(...args) {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => callback.apply(this, args), wait);
    };
}

function toValueList(value) {
    if (Array.isArray(value)) return value.flatMap(toValueList);
    if (value === null || value === undefined) return [];
    return String(value)
        .split(",")
        .map(item => item.trim())
        .filter(Boolean);
}

function uniqueSortedValues(values) {
    const seen = new Map();
    values.flatMap(toValueList).forEach(value => {
        const key = normalizeText(value);
        if (key && !seen.has(key)) seen.set(key, value.trim());
    });
    return [...seen.values()].sort((a, b) => a.localeCompare(b));
}

function getComparableValues(...values) {
    return values.flatMap(toValueList).map(normalizeText).filter(Boolean);
}

function valueMatchesFilter(selectedValue, ...candidateValues) {
    const selected = normalizeText(selectedValue);
    if (!selected || selected === "all") return true;
    return getComparableValues(...candidateValues).some(value => (
        value === selected || value.includes(selected) || selected.includes(value)
    ));
}

function getCounselorName(counselor) {
    return `${counselor?.firstName || ""} ${counselor?.lastName || ""}`.trim() || counselor?.username || "";
}

function getCounselorRating(counselor) {
    return Math.max(0, Math.min(5, normalizeNumber(counselor?.rating, 0)));
}

function getCounselorExperience(counselor) {
    return normalizeNumber(
        counselor?.experienceYears ??
        counselor?.yearsExperience ??
        counselor?.experience ??
        counselor?.totalReviews ??
        counselor?.totalRatings,
        0
    );
}

function getCounselorCreatedTime(counselor) {
    if (counselor?.createdAt) {
        const created = Date.parse(counselor.createdAt);
        if (Number.isFinite(created)) return created;
    }

    const objectIdPrefix = String(counselor?._id || "").slice(0, 8);
    const objectIdSeconds = parseInt(objectIdPrefix, 16);
    return Number.isFinite(objectIdSeconds) ? objectIdSeconds * 1000 : 0;
}

function getCounselorUpdatedSignature(counselor) {
    return [
        counselor?._id,
        counselor?.isOnline,
        counselor?.available,
        counselor?.activeIssues,
        counselor?.rating,
        counselor?.totalRatings,
        counselor?.totalReviews,
        counselor?.education,
        counselor?.qualification,
        JSON.stringify(counselor?.specialization ?? ""),
        counselor?.bio,
        counselor?.createdAt,
        counselor?.lastSeen
    ].join(":");
}

function isCounselorOnline(counselor) {
    return counselor?.isOnline === true;
}

function isCounselorAvailableNow(counselor) {
    if (!isCounselorOnline(counselor)) return false;
    if (typeof counselor?.available === "boolean") return counselor.available;
    if (counselor?.activeIssues !== undefined && counselor?.activeIssues !== null) {
        return normalizeNumber(counselor.activeIssues, BUSY_ISSUE_LIMIT) < BUSY_ISSUE_LIMIT;
    }
    return true;
}

function isCounselorBusy(counselor) {
    if (!isCounselorOnline(counselor)) return false;
    if (typeof counselor?.available === "boolean") return counselor.available === false;
    if (counselor?.activeIssues !== undefined && counselor?.activeIssues !== null) {
        return normalizeNumber(counselor.activeIssues, 0) >= BUSY_ISSUE_LIMIT;
    }
    return false;
}

function syncFilterState(patch = {}) {
    filters = {
        education: patch.education ?? document.getElementById(filterControls.education)?.value ?? filters.education,
        specialization: patch.specialization ?? document.getElementById(filterControls.specialization)?.value ?? filters.specialization,
        availability: patch.availability ?? document.getElementById(filterControls.availability)?.value ?? filters.availability,
        rating: patch.rating ?? document.getElementById(filterControls.rating)?.value ?? filters.rating,
        search: (patch.search ?? document.getElementById(filterControls.search)?.value ?? filters.search).trim(),
        sortBy: patch.sortBy ?? document.getElementById(filterControls.sortBy)?.value ?? filters.sortBy
    };
    return { ...filters };
}

function buildFilterCacheKey(counselors, currentFilters) {
    return `${JSON.stringify(currentFilters)}::${counselors.length}::${counselors.map(getCounselorUpdatedSignature).join("|")}`;
}

function matchesEducation(counselor, currentFilters) {
    return valueMatchesFilter(currentFilters.education, counselor?.education, counselor?.qualification);
}

function matchesSpecialization(counselor, currentFilters) {
    return valueMatchesFilter(currentFilters.specialization, counselor?.specialization, counselor?.skills);
}

function matchesAvailability(counselor, currentFilters) {
    if (currentFilters.availability === "all") return true;
    if (currentFilters.availability === "online") return isCounselorOnline(counselor);
    if (currentFilters.availability === "offline") return !isCounselorOnline(counselor);
    if (currentFilters.availability === "availableNow") return isCounselorAvailableNow(counselor);
    if (currentFilters.availability === "busy") return isCounselorBusy(counselor);
    return true;
}

function matchesRating(counselor, currentFilters) {
    if (currentFilters.rating === "all") return true;
    const rating = getCounselorRating(counselor);
    const selectedRating = normalizeNumber(currentFilters.rating, 0);
    return selectedRating >= 5 ? rating >= 5 : rating >= selectedRating;
}

function matchesSearch(counselor, currentFilters) {
    const query = normalizeText(currentFilters.search);
    if (!query) return true;

    const searchableText = [
        getCounselorName(counselor),
        counselor?.username,
        ...toValueList(counselor?.specialization),
        ...toValueList(counselor?.skills),
        counselor?.education,
        counselor?.qualification,
        counselor?.bio
    ].map(normalizeText).join(" ");

    return searchableText.includes(query);
}

function sortCounselors(a, b, sortBy) {
    const nameDiff = getCounselorName(a).localeCompare(getCounselorName(b));
    const onlineDiff = Number(isCounselorOnline(b)) - Number(isCounselorOnline(a));
    const availableDiff = Number(isCounselorAvailableNow(b)) - Number(isCounselorAvailableNow(a));
    const ratingDiff = getCounselorRating(b) - getCounselorRating(a);
    const ratingAscDiff = getCounselorRating(a) - getCounselorRating(b);
    const experienceDiff = getCounselorExperience(b) - getCounselorExperience(a);
    const newestDiff = getCounselorCreatedTime(b) - getCounselorCreatedTime(a);

    if (sortBy === "highestRated") return ratingDiff || onlineDiff || availableDiff || nameDiff;
    if (sortBy === "lowestRated") return ratingAscDiff || onlineDiff || nameDiff;
    if (sortBy === "mostExperienced") return experienceDiff || ratingDiff || onlineDiff || nameDiff;
    if (sortBy === "newestAdded") return newestDiff || onlineDiff || ratingDiff || nameDiff;

    return onlineDiff || availableDiff || ratingDiff || nameDiff;
}

function counselorFilterPipeline(counselors, currentFilters) {
    return [...(Array.isArray(counselors) ? counselors : [])]
        .filter(counselor => matchesEducation(counselor, currentFilters))
        .filter(counselor => matchesSpecialization(counselor, currentFilters))
        .filter(counselor => matchesAvailability(counselor, currentFilters))
        .filter(counselor => matchesRating(counselor, currentFilters))
        .filter(counselor => matchesSearch(counselor, currentFilters))
        .sort((a, b) => sortCounselors(a, b, currentFilters.sortBy));
}

function getFilteredCounselors(patch = {}) {
    const currentFilters = syncFilterState(patch);
    const cacheKey = buildFilterCacheKey(allCounselors, currentFilters);
    if (cacheKey === memoizedFilterKey) return memoizedFilterResult;

    memoizedFilterKey = cacheKey;
    memoizedFilterResult = counselorFilterPipeline(allCounselors, currentFilters);
    filteredCounselors = memoizedFilterResult;

    console.log("Total:", allCounselors.length);
    console.log("Filtered:", filteredCounselors.length);
    console.log("Filters:", currentFilters);

    return filteredCounselors;
}

function setSelectOptions(selectId, values, allLabel) {
    const select = document.getElementById(selectId);
    if (!select) return;

    const previousValue = select.value || "all";
    select.innerHTML = [`<option value="all">${allLabel}</option>`]
        .concat(values.map(value => `<option value="${escapeHTML(value)}">${escapeHTML(value)}</option>`))
        .join("");
    select.value = values.some(value => normalizeText(value) === normalizeText(previousValue)) ? previousValue : "all";
}

function hydrateFilterOptions(counselors) {
    setSelectOptions(
        filterControls.education,
        uniqueSortedValues(counselors.flatMap(counselor => [counselor?.education, counselor?.qualification])),
        "All Education"
    );
    setSelectOptions(
        filterControls.specialization,
        uniqueSortedValues(counselors.flatMap(counselor => [counselor?.specialization, counselor?.skills])),
        "All Specializations"
    );
}

const debouncedApplyCounselorFilters = debounce(() => {
    applyCounselorFilters();
}, 300);

function debouncedSearchCounselors() {
    debouncedApplyCounselorFilters();
}

function bindFilterControls() {
    document.getElementById(filterControls.search)?.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
            event.preventDefault();
            applyCounselorFilters();
        }
    });
}

function animateSearchFocus() {
    const icon = document.getElementById("searchIcon");
    if (!icon) return;
    icon.style.color = "#4361ee";
    icon.style.transform = "scale(1.1)";
}

function animateSearchBlur() {
    const icon = document.getElementById("searchIcon");
    if (!icon) return;
    icon.style.color = "#9aa3c0";
    icon.style.transform = "scale(1)";
}

function refreshCounselorsWithAnimation(btn) {
    btn?.querySelector("i")?.classList.add("fa-spin");
    showLoading();
    checkCounselorStatus().finally(() => {
        setTimeout(() => {
            btn?.querySelector("i")?.classList.remove("fa-spin");
            hideLoading();
            showToast("Refreshed", "Counselors list updated", "success");
        }, 500);
    });
}

function startChatbotWithAnimation(btn) {
    const icon = btn.querySelector("i");
    icon.style.transform = "rotate(15deg) scale(1.2)";
    setTimeout(() => { icon.style.transform = ""; startChatbot(); }, 200);
}

function observeCards() {
    const cards = document.querySelectorAll("#counselorsGrid .card");
    const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
            if (entry.isIntersecting) {
                entry.target.style.opacity = "1";
                entry.target.style.transform = "translateY(0) scale(1)";
            }
        });
    }, { threshold: 0.08 });

    cards.forEach((card, index) => {
        card.style.opacity = "0";
        card.style.transform = "translateY(28px) scale(0.97)";
        card.style.transition = `opacity 0.5s ${index * 0.07}s ease, transform 0.5s ${index * 0.07}s cubic-bezier(0.34,1.3,0.64,1)`;
        observer.observe(card);
    });
}

function viewCounselorProfile(counselorId) { showToast("Profile", "Viewing counselor profile", "info"); }
function showProfile() { showToast("Profile", "Viewing your profile", "info"); }
function refreshWeather() { showToast("Weather", "Weather information updated", "success"); }

async function startChat(counselorId, counselorName, isOnline = false) {
    if (!isOnline) showToast("Counselor Offline", `${counselorName} is offline. Message saved - they will reply when available.`, "info");
    try {
        showLoading();
        const res = await fetch("/api/chat/start", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "same-origin",
            body: JSON.stringify({ counselorId })
        });
        const data = await res.json();
        if (data.success) {
            sessionStorage.setItem("currentChatId", data.chatId);
            sessionStorage.setItem("currentCounselorId", counselorId);
            sessionStorage.setItem("currentCounselorName", counselorName);
            sessionStorage.setItem("anonymousId", data.anonymousId);
            window.location.href = `/chat/${data.chatId}`;
        } else {
            hideLoading();
            showToast("Error", data.message || "Unable to start chat", "error");
        }
    } catch(err) {
        hideLoading();
        showToast("Error", "Server error. Please try again.", "error");
    }
}

function startChatbot() {
    showLoading();
    showToast("Chatbot", "Starting anonymous chatbot session...", "info");
    setTimeout(() => { hideLoading(); window.location.href = "/chatbot"; }, 500);
}

document.addEventListener("DOMContentLoaded", function() {
    bindFilterControls();
    counselorRatingModal = new window.RatingModal({
        onSubmitted: (counselorId, data) => {
            updateCardRating(counselorId, data.avgRating, data.totalRatings);
            applyCounselorFilters();
            fetchCounselors(true);
            showToast("Thank You", "Your counselor rating was submitted.", "success");
        }
    });
});

function buildCounselorQuery(page = 1) {
    const params = new URLSearchParams();
    params.set("sort", "online");
    params.set("page", page);
    params.set("limit", COUNSELOR_FETCH_LIMIT);
    return params;
}

function showCounselorSkeletons() {
    const grid = document.getElementById("counselorsGrid");
    if (!grid) return;
    grid.innerHTML = Array.from({ length: 6 }, () => '<div class="counselor-skeleton"></div>').join("");
}

async function fetchCounselors(silent = false) {
    const fetchToken = ++counselorFetchToken;
    counselorLoading = true;
    const grid = document.getElementById("counselorsGrid");
    const meta = document.getElementById("counselorResultsMeta");
    if (!silent) showCounselorSkeletons();
    if (meta) meta.textContent = "Loading counselors...";

    try {
        const counselors = [];
        let page = 1;
        let hasMore = true;

        while (hasMore) {
            const res = await fetch(`/api/counselors/all?${buildCounselorQuery(page).toString()}`, {
                credentials: "same-origin"
            });
            const data = await res.json();
            if (!data.success) throw new Error(data.message || "Unable to load counselors");

            counselors.push(...(Array.isArray(data.counselors) ? data.counselors : []));
            hasMore = Boolean(data.pagination?.hasMore);
            page += 1;
        }

        if (fetchToken !== counselorFetchToken) return;

        allCounselors = counselors;
        counselorPage = 1;
        counselorHasMore = false;
        memoizedFilterKey = "";
        hydrateFilterOptions(allCounselors);
        renderFilteredCounselors();
    } catch (error) {
        console.error("Counselor fetch failed:", error);
        if (grid) {
            grid.innerHTML = `
                <div class="empty-state" style="grid-column:1/-1;">
                    <div class="empty-state-icon"><i class="fas fa-triangle-exclamation"></i></div>
                    <h5 style="font-family:'Sora',sans-serif;font-weight:700;color:#1a2639;margin-bottom:8px;">Counselors could not be loaded</h5>
                    <p style="color:#94a3b8;margin-bottom:20px;">Please try refreshing the list.</p>
                    <button class="clear-filters-btn" onclick="fetchCounselors(false)">Try Again</button>
                </div>`;
        }
        showToast("Error", "Failed to load counselors", "error");
    } finally {
        if (fetchToken === counselorFetchToken) counselorLoading = false;
        hideLoading();
    }
}

function renderFilteredCounselors() {
    const counselors = getFilteredCounselors();
    displayCounselors(counselors, { total: counselors.length, allTotal: allCounselors.length });
}

function applyCounselorFilters(patch = {}) {
    counselorPage = 1;
    syncFilterState(patch);
    renderFilteredCounselors();
}

function clearCounselorFilters() {
    filters = { ...DEFAULT_FILTERS };
    Object.entries(filterControls).forEach(([key, id]) => {
        const control = document.getElementById(id);
        if (control) control.value = filters[key];
    });
    counselorPage = 1;
    memoizedFilterKey = "";
    renderFilteredCounselors();
}

function loadMoreCounselors() {
    renderFilteredCounselors();
}

async function maybeShowRatingModal(counselorId, counselorName, messageCount) {
    if (!counselorId || messageCount < 10) return;
    const modalKey = `ratingPromptShown:${counselorId}`;
    if (sessionStorage.getItem(modalKey)) return;

    try {
        const data = await window.RatingService.check(counselorId);
        if (!data.success || data.hasRated) return;
        sessionStorage.setItem(modalKey, "1");
        counselorRatingModal?.open({ counselorId, counselorName });
    } catch (error) {
        console.error("Rating check failed:", error);
    }
}

function openRatingModal(counselorId, counselorName) {
    counselorRatingModal?.open({ counselorId, counselorName });
}

function closeRatingModal() {
    document.getElementById("ratingModal")?.classList.remove("show");
}

async function submitCounselorRating() {
    counselorRatingModal?.submit();
}

function checkCounselorStatus() {
    return fetchCounselors(true);
}

function initializeSocket() {
    socket = io({ auth: { userId: "<%= user._id %>", role: "student" } });

    socket.on("connect", () => fetchCounselors(true));
    socket.on("online-users", () => fetchCounselors(true));
    socket.on("counselor-list-update", () => fetchCounselors(true));
    socket.on("counselorProfileUpdated", () => fetchCounselors(true));

    socket.on("counselor-rating-updated", (payload) => {
        updateCardRating(payload.counselorId, payload.avgRating, payload.totalRatings);
        fetchCounselors(true);
    });

    socket.on("ratingPrompt", (payload) => {
        const counselorId = payload?.counselorId || sessionStorage.getItem("currentCounselorId");
        const counselorName = sessionStorage.getItem("currentCounselorName") || "your counselor";
        maybeShowRatingModal(counselorId, counselorName, payload?.messageCount || 10);
    });

    socket.on("recommendations-refresh", () => loadDashboardRecommendations(true));
}

function updateCounselorStatus(isOnline, count) {
    const statusEl = document.getElementById("counselorStatus");
    const statEl = document.getElementById("onlineCounselorCountStat");
    if (statEl) statEl.textContent = count;
    if (!statusEl) return;
    if (isOnline) {
        statusEl.className = "counselor-status-badge counselor-online";
        statusEl.innerHTML = `<span class="realtime-indicator"></span><span class="fw-bold">${count} Counselor${count > 1 ? "s" : ""} Online</span>`;
    } else {
        statusEl.className = "counselor-status-badge counselor-offline";
        statusEl.innerHTML = `<span class="realtime-indicator" style="background:#6c757d;animation:none;"></span><span>Offline - Chatbot Active</span>`;
    }
}

function displayCounselors(counselors, pagination = {}) {
    const grid = document.getElementById("counselorsGrid");
    const countEl = document.getElementById("onlineCounselorCount");
    const meta = document.getElementById("counselorResultsMeta");
    const total = pagination.total ?? counselors.length;
    const allTotal = pagination.allTotal ?? allCounselors.length;
    const onlineCount = counselors.filter(isCounselorOnline).length;

    if (countEl) countEl.textContent = total;
    updateCounselorStatus(onlineCount > 0, onlineCount);
    if (meta) {
        meta.textContent = `${total} matching counselor${total === 1 ? "" : "s"} of ${allTotal} total - ${onlineCount} online now`;
    }

    if (!grid) return;
    if (!counselors.length) {
        grid.innerHTML = `
            <div class="empty-state" style="grid-column:1/-1;">
                <div class="empty-state-icon"><i class="fas fa-user-check"></i></div>
                <h5 style="font-family:'Sora',sans-serif;font-weight:700;color:#1a2639;margin-bottom:8px;">No counselors found</h5>
                <p style="color:#94a3b8;margin-bottom:20px;">Try a broader education, specialization, rating, availability, or search filter.</p>
                <button class="clear-filters-btn" onclick="clearCounselorFilters()">
                    <i class="fas fa-filter-circle-xmark me-1"></i>Clear Filters
                </button>
            </div>`;
        return;
    }

    const html = counselors.map(c => {
        const fullName = escapeHTML(getCounselorName(c) || "Counselor");
        const firstNameOnly = escapeHTML(c.firstName || "Counselor");
        const photo = c.profilePhoto?.startsWith("/") ? c.profilePhoto : `/uploads/images/${c.profilePhoto || "default-avatar.png"}`;
        const rating = getCounselorRating(c);
        const totalRatings = normalizeNumber(c.totalRatings ?? c.totalReviews, 0);
        const specializationText = toValueList(c.specialization)[0] || toValueList(c.skills)[0] || "Student Wellness";
        const educationText = c.education || c.qualification || "Counseling Psychology";
        const skills = Array.isArray(c.skills) ? c.skills.slice(0, 3).join(", ") : "";
        const statusLabel = isCounselorOnline(c) ? (isCounselorAvailableNow(c) ? "Available Now" : "Busy") : (c.statusLabel === "Away" ? "Away" : "Offline");
        const labelClass = isCounselorOnline(c) ? "label-online" : "label-offline";
        const dotClass = isCounselorOnline(c) ? "dot-online" : "dot-offline";
        const cardClass = isCounselorOnline(c) ? "" : "counselor-offline-card";

        return `
        <div data-counselor-id="${escapeHTML(c._id)}">
            <div class="card ${cardClass}" onclick="viewCounselorProfile('${escapeHTML(c._id)}')">
                <div class="card-body">
                    <div class="avatar-wrap">
                        <img src="${escapeHTML(photo)}" class="rounded-circle" width="88" height="88" alt="${fullName}" onerror="this.src='/images/default-avatar.png'">
                        <span class="counselor-status-dot ${dotClass}"></span>
                    </div>
                    <h5>${fullName}</h5>
                    <div class="mb-1">
                        <span class="online-status-label ${labelClass}">
                            <i class="fas fa-circle" style="font-size:6px;"></i>${statusLabel}
                        </span>
                    </div>
                    <div class="specialization-badge">${escapeHTML(specializationText)}</div>
                    <div class="education-text"><i class="fas fa-graduation-cap"></i>${escapeHTML(educationText)}</div>
                    ${skills ? `<div class="education-text"><i class="fas fa-sparkles"></i>${escapeHTML(skills)}</div>` : ""}
                    <div class="counselor-rating" aria-label="Average rating ${rating}">
                        ${generateStars(rating)}
                        <span style="font-size:.78rem;color:#64748b;margin-left:6px;font-weight:700;">${rating ? rating.toFixed(1) : "New"} (${totalRatings})</span>
                    </div>
                    <button class="btn-chat ${!isCounselorOnline(c) ? "btn-chat-offline" : ""}"
                        onclick="event.stopPropagation(); startChat('${escapeHTML(c._id)}', '${fullName.replace(/'/g, "\\'")}', ${isCounselorOnline(c)})">
                        <i class="fas fa-comment-dots"></i>Chat with ${firstNameOnly}
                    </button>
                </div>
            </div>
        </div>`;
    }).join("");

    grid.innerHTML = html + (counselorHasMore ? `
        <div style="grid-column:1/-1;text-align:center;padding:8px 0 4px;">
            <button class="load-more-btn" onclick="loadMoreCounselors()">
                <i class="fas fa-chevron-down me-1"></i>Load More Counselors
            </button>
        </div>` : "");
    observeCards();
}

function updateCardRating(counselorId, newAvg, totalRatings) {
    const counselor = allCounselors.find(item => String(item._id) === String(counselorId));
    if (counselor) {
        counselor.rating = normalizeNumber(newAvg, counselor.rating || 0);
        if (totalRatings !== undefined) counselor.totalRatings = totalRatings;
    }
    memoizedFilterKey = "";
    renderFilteredCounselors();
}

function searchCounselors() {
    applyCounselorFilters();
}

document.addEventListener("keydown", function(e) {
    if (e.ctrlKey && e.key === "k") {
        e.preventDefault();
        document.getElementById("searchCounselors")?.focus();
    }
});
</script>

