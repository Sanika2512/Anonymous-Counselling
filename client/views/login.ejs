<%- include('partials/header') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white text-center py-4">
          <i class="fas fa-heart fa-3x mb-3"></i>
          <h4 class="mb-0">Welcome Back</h4>
          <p class="text-white-50 mb-0">Login to access your dashboard</p>
        </div>

        <div class="card-body p-4">
          <div id="alertMessage" class="alert d-none"></div>

          <form id="loginForm">
            <!-- EMAIL -->
            <div class="mb-3">
              <label for="email" class="form-label">
                <i class="fas fa-envelope me-2"></i>Email
              </label>
              <input type="email" class="form-control form-control-lg" id="email"
                     placeholder="Enter your email" required autofocus>
            </div>

            <!-- PASSWORD -->
            <div class="mb-3">
              <label for="password" class="form-label">
                <i class="fas fa-lock me-2"></i>Password
              </label>
              <input type="password" class="form-control form-control-lg" id="password"
                     placeholder="Enter your password" required>
            </div>

            <!-- ROLE -->
            <div class="mb-4">
              <label class="form-label">
                <i class="fas fa-user-tag me-2"></i>Login as
              </label>
              <div class="d-flex gap-3">
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="role"
                         id="studentRole" value="student" checked>
                  <label class="form-check-label" for="studentRole">
                    <i class="fas fa-graduation-cap me-1"></i>Student
                  </label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="role"
                         id="counselorRole" value="counselor">
                  <label class="form-check-label" for="counselorRole">
                    <i class="fas fa-user-md me-1"></i>Counselor
                  </label>
                </div>
                <div class="form-check">
                  <input class="form-check-input" type="radio" name="role"
                         id="adminRole" value="admin">
                  <label class="form-check-label" for="adminRole">
                    <i class="fas fa-shield-alt me-1"></i>Admin
                  </label>
                </div>
              </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100" id="loginBtn">
              <i class="fas fa-sign-in-alt me-2"></i>Login
            </button>
          </form>
        </div>

        <div class="card-footer bg-light text-center py-3">
          <p class="mb-0 text-muted">
            <i class="fas fa-shield-alt me-1"></i>
            Your privacy is protected. All data is encrypted.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
const loginForm = document.getElementById('loginForm');
const loginBtn = document.getElementById('loginBtn');
const alertBox = document.getElementById('alertMessage');

loginForm.addEventListener('submit', async (e) => {
  e.preventDefault();

  const email = document.getElementById('email').value.trim();
  const password = document.getElementById('password').value.trim();
  const role = document.querySelector('input[name="role"]:checked');

  if (!email) return showAlert("danger", "Email is required");
  if (!password) return showAlert("danger", "Password is required");
  if (password.length < 6) return showAlert("danger", "Password must be at least 6 characters");

  loginBtn.disabled = true;
  loginBtn.innerHTML = `<i class="fas fa-spinner fa-spin me-2"></i>Logging in...`;

  try {
    const response = await fetch('/api/auth/login', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      credentials: "same-origin",
      body: JSON.stringify({
        email,
        password,
        role: role.value
      })
    });

    const data = await response.json();

    if (data.success) {
      showAlert("success", "Login successful! Redirecting...");

      setTimeout(() => {
        if (data.user.role === "admin") {
          window.location.href = "/admin";
        } else if (data.user.role === "counselor") {
          window.location.href = "/counselor-dashboard";
        } else {
          window.location.href = "/student-dashboard";
        }
      }, 1500);

    } else {
      showAlert("danger", data.message || "Invalid credentials");
      resetButton();
    }

  } catch (error) {
    console.error("Login error:", error);
    showAlert("danger", "Server error. Try again later.");
    resetButton();
  }
});

function showAlert(type, message) {
  alertBox.className = `alert alert-${type}`;
  alertBox.innerHTML = `
    <i class="fas fa-${type === "success" ? "check-circle" : "exclamation-circle"} me-2"></i>
    ${message}
  `;
  alertBox.classList.remove("d-none");

  setTimeout(() => alertBox.classList.add("d-none"), 4000);
}

function resetButton() {
  loginBtn.disabled = false;
  loginBtn.innerHTML = `<i class="fas fa-sign-in-alt me-2"></i>Login`;
}
</script>

<%- include('partials/footer') %>
