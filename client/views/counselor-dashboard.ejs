    width: 130px;
    height: 130px;
    border-radius: 50%;
    overflow: hidden;
    border: 4px solid white;
    box-shadow: 0 5px 15px rgba(42, 92, 143, 0.2);
}

.avatar-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.status-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: white;
    border-radius: 30px;
    padding: 6px 16px;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.1);
    border: 1px solid var(--border-color);
    margin-top: 8px;
}

.online-dot {
    width: 10px;
    height: 10px;
    background: var(--success-color);
    border-radius: 50%;
    display: inline-block;
    margin-right: 6px;
    position: relative;
}

.online-dot::after {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: var(--success-color);
    border-radius: 50%;
    opacity: 0.3;
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0% { transform: scale(1); opacity: 0.3; }
    70% { transform: scale(1.5); opacity: 0; }
    100% { transform: scale(1.5); opacity: 0; }
}

.profile-info {
    margin-top: 16px;
}

.profile-name {
    font-size: 24px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 4px;
}

.profile-name span {
    font-weight: 400;
    color: var(--text-secondary);
    font-size: 20px;
}

.profile-title {
    font-size: 18px;
    color: var(--primary-color);
    font-weight: 600;
    margin: 8px 0 4px;
    padding: 0 0 8px;
    border-bottom: 2px dashed var(--border-color);
}

.profile-education {
    font-size: 15px;
    color: var(--text-secondary);
    margin: 8px 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
}

.profile-bio {
    font-size: 14px;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 12px 0;
    padding: 12px;
    background: var(--light-bg);
    border-radius: 12px;
    border-left: 3px solid var(--primary-color);
    text-align: left;
}

.role-badge {
    display: inline-block;
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
    font-size: 13px;
    font-weight: 600;
    padding: 6px 16px;
    border-radius: 30px;
    margin: 8px 0;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    box-shadow: 0 4px 10px rgba(74, 144, 226, 0.2);
}

.update-profile-btn {
    background: white;
    border: 2px solid var(--primary-color);
    color: var(--primary-color);
    padding: 10px 24px;
    border-radius: 30px;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
}

.update-profile-btn:hover {
    background: var(--primary-color);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(42, 92, 143, 0.3);
}

/* Stats Container */
.stats-container {
    margin-top: 24px;
}

.stats-header h3 {
    font-size: 16px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 12px;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
}

.stat-card {
    background: white;
    border-radius: 16px;
    padding: 16px 12px;
    border: 1px solid var(--border-color);
    transition: all 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
    border-color: var(--primary-color);
}

.stat-value {
    font-size: 28px;
    font-weight: 700;
    color: var(--primary-color);
    line-height: 1;
    margin-bottom: 6px;
}

.stat-label {
    font-size: 12px;
    color: var(--text-secondary);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

.stat-card.emergency .stat-value {
    color: var(--danger-color);
}

/* Online Counselors */
.online-counselor-item {
    display: flex;
    align-items: center;
    padding: 8px 12px;
    background: white;
    border-radius: 10px;
    margin-bottom: 8px;
    border: 1px solid var(--border-color);
}

.online-counselor-item .online-dot {
    width: 8px;
    height: 8px;
    margin-right: 8px;
}

/* Conversations Panel */
.conversations-panel {
    width: var(--conversations-width);
    height: calc(100vh - var(--navbar-height));
    position: sticky; /* ← हे add करा */
    top: var(--navbar-height); /* ← हे add करा */
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: white;
    border-right: 1px solid var(--border-color);
    flex-shrink: 0;
    align-self: flex-start;
}
.conversations-header {
    flex-shrink: 0;         /* ← header never scrolls away */
    padding: 20px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: white;
}


.conversations-header h5 {
    margin: 0;
    font-weight: 600;
    color: var(--text-primary);
}

.conversations-search {
    flex-shrink: 0;         /* ← search bar stays fixed */
    padding: 15px 20px;
    position: relative;
}

.conversations-search .search-icon {
    position: absolute;
    left: 35px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-secondary);
    font-size: 14px;
}

.conversations-search input {
    padding-left: 35px;
    border-radius: 30px;
    border: 1px solid var(--border-color);
    background: var(--light-bg);
}
.conversations-list {
    flex: 1;
    overflow-y: auto;      
    padding: 10px 15px;
    min-height: 0;          
}


.conversation-item {
    display: flex;
    padding: 15px;
    border-radius: 15px;
    margin-bottom: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
    background: white;
    border: 1px solid var(--border-color);
}

.conversation-item:hover {
    background: var(--light-bg);
    transform: translateX(5px);
}

.conversation-item.active {
    background: #e3f2fd;
    border-color: var(--primary-color);
}

.conversation-item.emergency {
    border-left: 4px solid var(--danger-color);
    background: #fff5f5;
}

.conversation-avatar {
    margin-right: 12px;
    color: var(--primary-color);
}

.conversation-content {
    flex: 1;
    min-width: 0;
}

.conversation-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
}

.conversation-name {
    font-weight: 600;
    color: var(--text-primary);
    font-size: 14px;
}

.conversation-time {
    font-size: 11px;
    color: var(--text-secondary);
}

.conversation-preview {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 4px;
}

.preview-text {
    font-size: 13px;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 180px;
}

.unread-badge {
    background: var(--primary-color);
    color: white;
    font-size: 11px;
    font-weight: 600;
    padding: 2px 6px;
    border-radius: 12px;
    min-width: 20px;
    text-align: center;
}

.conversation-meta {
    display: flex;
    gap: 5px;
}

.conversation-meta .badge {
    font-size: 10px;
    padding: 2px 6px;
}

.empty-conversations {
    text-align: center;
    padding: 40px 20px;
    color: var(--text-secondary);
}


.chat-panel {
     flex: 1;
    height: calc(100vh - var(--navbar-height));
    position: sticky; 
    top: var(--navbar-height); 
    display: flex;
    flex-direction: column;
    overflow: hidden;
    min-width: 0;
    align-self: flex-start;
}
.no-chat-selected {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--light-bg);
    overflow: hidden;
}
.empty-state {
    text-align: center;
    padding: 40px;
}

.empty-state-icon {
    width: 80px;
    height: 80px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
}

.empty-state-icon i {
    font-size: 32px;
    color: var(--primary-color);
}

/* Chat Window */

.chat-window {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;       /* ← window itself doesn't scroll */
    min-height: 0;          /* ← critical */
}


.chat-header {
    flex-shrink: 0;         /* ← chat header stays fixed */
    padding: 15px 20px;
    background: white;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.chat-header-info {
    display: flex;
    align-items: center;
    gap: 12px;
}

.student-avatar i {
    font-size: 40px;
    color: var(--primary-color);
}

.emergency-badge {
    background: var(--danger-color);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}

.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    background: var(--light-bg);
    display: flex;
    flex-direction: column;
    gap: 10px;
      min-height: 0;
}

.empty-messages {
    text-align: center;
    color: var(--text-secondary);
    padding: 40px;
}

/* Chat messages */
.message {
    display: flex;
    flex-direction: column;
    max-width: 70%;
    position: relative;  /* ← हे add केले */
}
.msg-menu-btn {
    display: none;
    position: absolute;
    background: none;
    border: none;
    cursor: pointer;
    color: #888;
    font-size: 12px;
    padding: 3px 6px;
    top: 6px;
    z-index: 10;
}
.message-outgoing .msg-menu-btn {
    left: -20px;
}

.message-incoming .msg-menu-btn {
    right: -20px;
}

.message:hover .msg-menu-btn {
    display: block;
}

.message-incoming {
    align-self: flex-start; /* Left side for student */
}

.message-outgoing {
    align-self: flex-end;   /* Right side for counselor */
}

.message-bubble {
    padding: 10px 14px;
    border-radius: 18px;
    background: #e3f2fd; /* Default bubble color */
    word-wrap: break-word;
    max-width: 100%;
}


.message-incoming .message-bubble {
    background: #ffffff;   /* pure white */
    color: #000;
    border: 1px solid #e5e5e5;
    border-top-left-radius: 0;
}

.message-outgoing .message-bubble {
       background: #dcf8c6;
    color: #000;
    border-top-right-radius: 0;
}
  

.message-time {
    font-size: 10px;
    color: #6c757d;
    margin-top: 2px;
    display: flex;
    justify-content: flex-end;
    gap: 4px;
}
.chat-input-area {
     flex-shrink: 0; 
    padding: 15px 20px;
    background: white;
    border-top: 1px solid var(--border-color);
}

.chat-input-area .input-group {
    gap: 8px;
}

.chat-input-area .form-control {
    border-radius: 25px;
    padding: 10px 15px;
    border: 1px solid var(--border-color);
    resize: none;
}

.chat-input-area .btn {
    border-radius: 25px;
    padding: 10px 15px;
}

.quick-responses {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: center;
}

.quick-responses .btn-sm {
    border-radius: 20px;
    font-size: 12px;
    padding: 4px 12px;
}

/* Counselor chat polish */
.chat-panel {
    background: #eef4f8;
}

.chat-window {
    margin: 12px 16px 16px;
    background: #f7fafc;
    border: 1px solid #dbe5ee;
    border-radius: 18px;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
}

.no-chat-selected {
    margin: 12px 16px 16px;
    background:
        linear-gradient(135deg, rgba(42, 92, 143, 0.08), rgba(74, 144, 226, 0.08)),
        #f8fafc;
    border: 1px solid #dbe5ee;
    border-radius: 18px;
}

.chat-header {
    padding: 16px 20px;
    background: linear-gradient(135deg, #ffffff 0%, #f5f9fc 100%);
    border-bottom: 1px solid #dbe5ee;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.85) inset;
}

.student-avatar {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e7f0f8;
    color: var(--primary-color);
    border: 1px solid #cfe0ee;
}

.student-avatar i {
    font-size: 22px;
    color: inherit;
}

.chat-title-block {
    min-width: 0;
}

.chat-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
}

.chat-title-row h6 {
    color: #16293a;
    font-size: 16px;
    font-weight: 700;
}

.chat-secure-pill {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 3px 9px;
    border-radius: 999px;
    background: #e9f8ef;
    color: #137b3b;
    font-size: 11px;
    font-weight: 700;
}

.chat-header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
}

.chat-header-actions .btn {
    width: 36px;
    height: 36px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
}

.chat-messages {
    padding: 24px;
    background:
        linear-gradient(rgba(247, 250, 252, 0.92), rgba(247, 250, 252, 0.92)),
        radial-gradient(circle at 15% 20%, rgba(42, 92, 143, 0.09), transparent 24%),
        radial-gradient(circle at 85% 10%, rgba(37, 99, 235, 0.08), transparent 22%);
    gap: 12px;
}

.message {
    max-width: min(68%, 620px);
}

.message-bubble {
    padding: 11px 15px;
    border-radius: 16px;
    font-size: 15px;
    line-height: 1.45;
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.06);
}

.message-incoming .message-bubble {
    background: #ffffff;
    color: #152232;
    border: 1px solid #e1e8ef;
    border-top-left-radius: 6px;
}

.message-outgoing .message-bubble {
    background: linear-gradient(135deg, #dcfce7 0%, #c8f3d9 100%);
    color: #10271a;
    border: 1px solid #b8e7c9;
    border-top-right-radius: 6px;
}

.message-time {
    margin-top: 4px;
    padding: 0 4px;
    font-size: 11px;
    color: #718096;
}

.chat-input-area {
    padding: 14px 18px 16px;
    background: #ffffff;
    border-top: 1px solid #dbe5ee;
}

.counselor-composer {
    display: flex;
    align-items: flex-end;
    gap: 10px;
    padding: 8px;
    background: #f8fafc;
    border: 1px solid #dbe5ee;
    border-radius: 16px;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.05);
}

.counselor-composer textarea.form-control {
    min-height: 44px;
    max-height: 120px;
    padding: 11px 12px;
    border: 0;
    border-radius: 12px;
    background: transparent;
    box-shadow: none;
}

.counselor-composer textarea.form-control:focus {
    box-shadow: none;
    border: 0;
}

.composer-icon-btn,
.composer-send-btn,
.voice-toolbar .voice-round-btn {
    width: 44px;
    height: 44px;
    border-radius: 14px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
}

.composer-send-btn {
    border: 0;
    background: linear-gradient(135deg, #1769ff, #1254d8);
    box-shadow: 0 10px 18px rgba(18, 84, 216, 0.22);
}

.voice-toolbar {
    margin-top: 10px;
    padding: 10px;
    background: #f8fafc;
    border: 1px solid #dbe5ee;
    border-radius: 16px;
}

.voice-preview {
    border-color: #cfe0ee;
    background: #ffffff;
}

.voice-error {
    border-radius: 12px;
}

.quick-responses {
    margin-top: 10px;
}

.quick-responses .btn-sm {
    background: #f8fafc;
    border: 1px solid #dbe5ee;
    color: #2d4d68;
}

/* Modal Styles (Unchanged) */
.modal-content {
    border-radius: 24px;
    border: none;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
}

.modal-header {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
    border-radius: 24px 24px 0 0;
    padding: 20px 24px;
    border: none;
}

.modal-header .btn-close {
    filter: brightness(0) invert(1);
}

.modal-body {
    padding: 24px;
}

.form-control, .form-select {
    border: 2px solid var(--border-color);
    border-radius: 12px;
    padding: 12px 16px;
    font-size: 14px;
    transition: all 0.3s ease;
}

.form-control:focus, .form-select:focus {
    border-color: var(--primary-color);
    box-shadow: 0 0 0 3px rgba(42, 92, 143, 0.1);
}

.modal-avatar-preview {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 16px;
    border: 3px solid var(--primary-color);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
}

.modal-avatar-preview img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.btn-submit {
    background: linear-gradient(135deg, var(--primary-color), var(--secondary-color));
    color: white;
    border: none;
    border-radius: 12px;
    padding: 14px;
    font-weight: 600;
    font-size: 16px;
    transition: all 0.3s ease;
    margin-top: 16px;
}

.btn-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(42, 92, 143, 0.3);
}

/* Scrollbar Styling */
.profile-sidebar::-webkit-scrollbar,
.conversations-list::-webkit-scrollbar,
.chat-messages::-webkit-scrollbar {
    width: 5px;
}

.profile-sidebar::-webkit-scrollbar-track,
.conversations-list::-webkit-scrollbar-track,
.chat-messages::-webkit-scrollbar-track {
    background: #f1f1f1;
}

.profile-sidebar::-webkit-scrollbar-thumb,
.conversations-list::-webkit-scrollbar-thumb,
.chat-messages::-webkit-scrollbar-thumb {
    background: #c1c1c1;
    border-radius: 10px;
}

.profile-sidebar::-webkit-scrollbar-thumb:hover,
.conversations-list::-webkit-scrollbar-thumb:hover,
.chat-messages::-webkit-scrollbar-thumb:hover {
    background: #a8a8a8;
}

/* Responsive */
.dashboard-container,
.profile-sidebar,
.conversations-panel,
.chat-window {
    min-width: 0;
}

.dashboard-container {
    height: calc(100dvh - var(--navbar-height));
    min-height: calc(100dvh - var(--navbar-height));
}

.profile-sidebar {
    flex: 0 0 var(--sidebar-width);
}

.conversations-panel {
    flex: 0 0 var(--conversations-width);
}

.chat-header-info,
.conversation-content,
.message-content,
.chat-input-area,
.counselor-composer {
    min-width: 0;
}

.message-bubble,
.reply-preview-bubble {
    overflow-wrap: anywhere;
}

.voice-bubble {
    max-width: 100%;
}

.voice-player {
    min-width: 0;
}

.voice-seek {
    min-width: 82px;
    max-width: 100%;
}

.modal-dialog {
    width: min(100% - 24px, 640px);
    margin-left: auto;
    margin-right: auto;
}

.modal-body {
    max-height: min(72dvh, 720px);
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
}

@media (max-width: 1200px) {
    :root {
        --sidebar-width: 280px;
        --conversations-width: 300px;
    }
}

@media (max-width: 992px) {
    .dashboard-container {
        display: grid;
        grid-template-columns: minmax(260px, 36%) minmax(0, 1fr);
        grid-template-rows: auto minmax(0, 1fr);
        height: auto;
        min-height: calc(100dvh - var(--navbar-height));
        overflow: visible;
        position: static;
        top: auto;
    }

    .profile-sidebar {
        grid-column: 1 / -1;
        width: 100%;
        height: auto;
        min-height: 0;
        position: static;
        flex: none;
        align-self: stretch;
        padding: 18px;
    }

    .profile-card {
        display: grid;
        grid-template-columns: auto minmax(0, 1fr);
        align-items: center;
        gap: 16px;
        text-align: left;
    }

    .profile-stats,
    .profile-actions {
        grid-column: 1 / -1;
    }

    .conversations-panel {
        width: auto;
        height: calc(100dvh - 260px);
        min-height: 520px;
        position: static;
        flex: none;
    }

    .chat-window {
        min-height: 520px;
        height: calc(100dvh - 260px);
    }
}

@media (max-width: 767px) {
    .dashboard-container {
        display: flex;
        flex-direction: column;
        min-height: calc(100dvh - 64px);
    }

    .profile-sidebar {
        padding: 14px;
    }

    .profile-card {
        grid-template-columns: 1fr;
        text-align: center;
        border-radius: 18px;
        padding: 18px 14px;
    }

    .profile-image,
    .modal-avatar-preview {
        width: 96px;
        height: 96px;
        margin-left: auto;
        margin-right: auto;
    }

    .profile-stats {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

