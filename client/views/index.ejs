<%- include('partials/header') %>

<!-- Custom CSS for Homepage -->
<style>
    :root {
        --primary-soft: #6B8CFF;
        --primary-gentle: #8AA9FF;
        --secondary-soothing: #A8D5E5;
        --accent-calm: #B8E0D2;
        --text-warm: #4A4A4A;
        --text-soft: #6B6B6B;
        --bg-light: #FAFCFE;
        --card-soft: #FFFFFF;
        --shadow-gentle: 0 20px 40px -15px rgba(107, 140, 255, 0.2);
        --gradient-calm: linear-gradient(145deg, #FFFFFF 0%, #F5F9FF 100%);
    }

    body {
        background-color: var(--bg-light);
        font-family: 'Inter', 'Poppins', sans-serif;
        overflow-x: hidden;
    }

    /* Hero Section */
    .hero-wrapper {
        position: relative;
        overflow: hidden;
        min-height: 90vh;
        display: flex;
        align-items: center;
        background: linear-gradient(135deg, #F0F7FF 0%, #E6F0FA 100%);
    }

    .floating-shapes {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        z-index: 1;
        pointer-events: none;
    }

    .shape {
        position: absolute;
        background: rgba(107, 140, 255, 0.03);
        border-radius: 50%;
        animation: float 20s infinite ease-in-out;
    }

    .shape-1 {
        width: 300px;
        height: 300px;
        top: -100px;
        right: -100px;
        background: linear-gradient(145deg, rgba(168, 213, 229, 0.1), rgba(107, 140, 255, 0.1));
        animation-delay: -2s;
    }

    .shape-2 {
        width: 200px;
        height: 200px;
        bottom: 50px;
        left: 50px;
        background: linear-gradient(145deg, rgba(184, 224, 210, 0.1), rgba(138, 169, 255, 0.1));
        animation-delay: -5s;
    }

    .shape-3 {
        width: 150px;
        height: 150px;
        top: 200px;
        left: 20%;
        background: linear-gradient(145deg, rgba(107, 140, 255, 0.05), rgba(168, 213, 229, 0.05));
        animation-delay: -8s;
    }

    @keyframes float {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        25% { transform: translate(20px, 20px) rotate(5deg); }
        50% { transform: translate(-10px, 30px) rotate(-5deg); }
        75% { transform: translate(-20px, 10px) rotate(3deg); }
    }

    .hero-content {
        position: relative;
        z-index: 10;
        padding: 80px 0;
    }

    .welcome-badge {
        background: rgba(107, 140, 255, 0.1);
        color: var(--primary-soft);
        padding: 8px 20px;
        border-radius: 50px;
        display: inline-block;
        font-size: 0.9rem;
        font-weight: 500;
        margin-bottom: 25px;
        backdrop-filter: blur(5px);
        animation: slideInDown 0.8s ease;
        border: 1px solid rgba(107, 140, 255, 0.2);
    }

    .hero-title {
        font-size: 3.8rem;
        font-weight: 700;
        line-height: 1.2;
        margin-bottom: 25px;
        color: #1A2B4C;
        animation: slideInUp 0.8s ease 0.2s both;
    }

    .hero-title span {
        background: linear-gradient(135deg, var(--primary-soft), #4A6FA5);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        display: inline-block;
    }

    .hero-subtitle {
        font-size: 1.2rem;
        color: var(--text-soft);
        margin-bottom: 35px;
        line-height: 1.8;
        max-width: 600px;
        animation: slideInUp 0.8s ease 0.4s both;
    }

    .hero-buttons {
        animation: slideInUp 0.8s ease 0.6s both;
        margin-bottom: 40px;
    }

    .btn-primary-calm {
        background: var(--primary-soft);
        color: white;
        padding: 15px 35px;
        border-radius: 50px;
        font-weight: 600;
        border: none;
        transition: all 0.3s ease;
        box-shadow: 0 10px 25px rgba(107, 140, 255, 0.3);
        position: relative;
        overflow: hidden;
    }

    .btn-primary-calm::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
        transition: left 0.5s ease;
    }

    .btn-primary-calm:hover::before {
        left: 100%;
    }

    .btn-primary-calm:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 35px rgba(107, 140, 255, 0.4);
        background: #5A7AE0;
    }

    .btn-outline-calm {
        background: transparent;
        color: var(--primary-soft);
        padding: 15px 35px;
        border-radius: 50px;
        font-weight: 600;
        border: 2px solid var(--primary-soft);
        transition: all 0.3s ease;
        margin-left: 15px;
    }

    .btn-outline-calm:hover {
        background: var(--primary-soft);
        color: white;
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(107, 140, 255, 0.2);
    }

    .hero-image {
        position: relative;
        z-index: 10;
        animation: fadeInRight 1s ease 0.4s both;
    }

    .hero-image img {
        border-radius: 30px;
        box-shadow: var(--shadow-gentle);
        transition: transform 0.5s ease;
    }

    .hero-image:hover img {
        transform: scale(1.02);
    }

    .floating-card {
        position: absolute;
        background: white;
        padding: 15px 25px;
        border-radius: 60px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.1);
        display: flex;
        align-items: center;
        gap: 10px;
        animation: float 6s infinite ease-in-out;
        backdrop-filter: blur(5px);
        background: rgba(255,255,255,0.9);
    }

    .card-1 {
        top: 20%;
        right: -20px;
        animation-delay: -1s;
    }

    .card-2 {
        bottom: 20%;
        left: -20px;
        animation-delay: -3s;
    }

    .floating-card i {
        color: var(--primary-soft);
        font-size: 1.2rem;
    }

    /* Stats Section */
    .stats-wrapper {
        background: white;
        padding: 40px 0;
        border-radius: 50px 50px 0 0;
        margin-top: -50px;
        position: relative;
        z-index: 20;
        box-shadow: 0 -10px 30px rgba(0,0,0,0.02);
    }

    .stat-item {
        text-align: center;
        padding: 20px;
        transition: transform 0.3s ease;
    }

    .stat-item:hover {
        transform: translateY(-10px);
    }

    .stat-number {
        font-size: 3rem;
        font-weight: 700;
        background: linear-gradient(135deg, var(--primary-soft), #4A6FA5);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        line-height: 1;
        margin-bottom: 5px;
    }

    .stat-label {
        color: var(--text-soft);
        font-size: 1rem;
        font-weight: 500;
    }

    /* Features Section */
    .section-title {
        text-align: center;
        margin-bottom: 60px;
    }

    .section-title h2 {
        font-size: 2.5rem;
        font-weight: 600;
        color: #1A2B4C;
        margin-bottom: 15px;
        position: relative;
        display: inline-block;
    }

    .section-title h2::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 60px;
        height: 3px;
        background: linear-gradient(90deg, var(--primary-soft), var(--secondary-soothing));
        border-radius: 3px;
    }

    .section-title p {
        color: var(--text-soft);
        font-size: 1.1rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .feature-card {
        background: var(--gradient-calm);
        padding: 40px 25px;
        border-radius: 30px;
        text-align: center;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        border: 1px solid rgba(107, 140, 255, 0.1);
        height: 100%;
        box-shadow: 0 10px 30px -15px rgba(107, 140, 255, 0.1);
    }

    .feature-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 5px;
        background: linear-gradient(90deg, var(--primary-soft), var(--secondary-soothing));
        transform: scaleX(0);
        transition: transform 0.4s ease;
    }

    .feature-card:hover::before {
        transform: scaleX(1);
    }

    .feature-card:hover {
        transform: translateY(-15px);
        box-shadow: 0 30px 45px -20px rgba(107, 140, 255, 0.3);
        border-color: rgba(107, 140, 255, 0.2);
    }

    .feature-icon-wrapper {
        width: 100px;
        height: 100px;
        margin: 0 auto 25px;
        background: linear-gradient(135deg, rgba(107, 140, 255, 0.1), rgba(168, 213, 229, 0.1));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .feature-card:hover .feature-icon-wrapper {
        transform: scale(1.1) rotate(5deg);
    }

    .feature-icon-wrapper i {
        font-size: 3rem;
        background: linear-gradient(135deg, var(--primary-soft), #4A6FA5);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .feature-card h5 {
        font-size: 1.3rem;
        font-weight: 600;
        color: #1A2B4C;
        margin-bottom: 15px;
    }

    .feature-card p {
        color: var(--text-soft);
        margin: 0;
        line-height: 1.7;
    }

    /* Categories Section */
    .categories-wrapper {
        background: linear-gradient(135deg, #F5F9FF, #E8F0FE);
        padding: 80px 0;
        position: relative;
        overflow: hidden;
    }

    .category-card {
        background: white;
        padding: 30px 25px;
        border-radius: 30px;
        text-align: center;
        transition: all 0.4s ease;
        position: relative;
        overflow: hidden;
        cursor: pointer;
        border: 1px solid rgba(107, 140, 255, 0.1);
        height: 100%;
        box-shadow: 0 10px 25px -10px rgba(0,0,0,0.05);
    }

    .category-card:hover {
        transform: translateY(-10px) scale(1.02);
        border-color: var(--primary-soft);
        box-shadow: 0 25px 40px -15px rgba(107, 140, 255, 0.3);
    }

    .category-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .category-card:hover .category-icon {
        transform: rotateY(180deg);
    }

    .category-icon i {
        font-size: 2.5rem;
    }

    .category-badge {
        display: inline-block;
        padding: 8px 20px;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-bottom: 15px;
    }

    /* Emergency Banner */
    .emergency-wrapper {
        background: linear-gradient(135deg, #FF6B6B, #FF8E8E);
        padding: 60px 0;
        position: relative;
        overflow: hidden;
    }

    .emergency-content {
        position: relative;
        z-index: 10;
    }

    .emergency-pulse {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 200%;
        height: 200%;
        background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
        animation: pulse 4s infinite;
    }

    @keyframes pulse {
        0% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
        50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.2; }
        100% { transform: translate(-50%, -50%) scale(0.8); opacity: 0.5; }
    }

    .emergency-card {
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
        border-radius: 30px;
        padding: 25px;
        transition: all 0.3s ease;
    }

    .emergency-card:hover {
        transform: translateY(-5px);
        background: rgba(255,255,255,0.2);
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    /* Testimonial Section */
    .testimonial-section {
        padding: 80px 0;
        background: white;
    }

    .testimonial-card {
        background: var(--gradient-calm);
        padding: 30px;
        border-radius: 30px;
        border: 1px solid rgba(107, 140, 255, 0.1);
        transition: all 0.3s ease;
        margin: 15px;
    }

    .testimonial-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-gentle);
    }

    .testimonial-text {
        font-size: 1rem;
        line-height: 1.8;
        color: var(--text-soft);
        margin-bottom: 20px;
        font-style: italic;
    }

    .testimonial-author {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .support-wall-section {
        padding: 80px 0;
        background:
            radial-gradient(circle at top left, rgba(107, 140, 255, 0.16), transparent 34%),
            linear-gradient(135deg, #f8fbff 0%, #eef7f4 100%);
    }

    .wall-shell {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 320px;
        gap: 24px;
        align-items: start;
    }

    .wall-toolbar,
    .wall-card,
    .wall-sidebar-panel {
        background: rgba(255,255,255,0.78);
        border: 1px solid rgba(107,140,255,0.18);
        border-radius: 20px;
        box-shadow: 0 18px 45px rgba(62, 89, 132, 0.12);
        backdrop-filter: blur(14px);
    }

    .wall-toolbar {
        padding: 18px;
        margin-bottom: 18px;
    }

    .wall-grid {
        display: grid;
        gap: 18px;
    }

    .wall-card {
        padding: 22px;
        animation: slideInUp 0.35s ease both;
    }

    .wall-card-header,
    .wall-actions,
    .wall-reply-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
    }

    .wall-anon {
        font-weight: 800;
        color: #1a2b4c;
    }

    .wall-chip {
        border-radius: 999px;
        padding: 6px 11px;
        font-size: 0.76rem;
        font-weight: 700;
        background: #eef6ff;
        color: #2563eb;
    }

    .wall-chip.resolved {
        background: #dcfce7;
        color: #15803d;
    }

    .wall-chip.distressed {
        background: #fee2e2;
        color: #b91c1c;
    }

    .wall-chip.positive {
        background: #dcfce7;
        color: #15803d;
    }

    .wall-card h3 {
        font-size: 1.25rem;
        margin: 14px 0 8px;
        color: #14213d;
    }

    .wall-card p {
        color: #52627a;
        line-height: 1.65;
    }

    .wall-media {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 10px;
        margin: 14px 0;
    }

    .wall-media img,
    .wall-media video {
        width: 100%;
        border-radius: 14px;
        max-height: 240px;
        object-fit: cover;
        background: #0f172a;
    }

    .wall-recommendations {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 12px 0;
    }

    .wall-action-btn {
        border: 1px solid #dbe5f5;
        background: #fff;
        color: #1f2f46;
        border-radius: 999px;
        padding: 8px 12px;
        font-weight: 700;
        font-size: 0.82rem;
    }

    .wall-action-btn.active {
        background: #2563eb;
        color: #fff;
        border-color: #2563eb;
    }

    .wall-replies {
        border-top: 1px solid #e5edf7;
        margin-top: 16px;
        padding-top: 14px;
        display: grid;
        gap: 10px;
    }

    .wall-reply {
        background: #f8fbff;
        border: 1px solid #e4edf8;
        border-radius: 14px;
        padding: 12px;
        margin-left: var(--reply-indent, 0);
    }

    .wall-reply.counselor {
        background: #ecfdf5;
        border-color: #bbf7d0;
    }

    .wall-sidebar {
        display: grid;
        gap: 16px;
        position: sticky;
        top: 90px;
    }

    .wall-sidebar-panel {
        padding: 18px;
    }

    .wall-stat {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #e5edf7;
    }

    .wall-stat:last-child {
        border-bottom: 0;
    }

    .wall-empty {
        text-align: center;
        padding: 42px;
        color: #64748b;
        border: 2px dashed rgba(107,140,255,0.24);
        border-radius: 18px;
        background: rgba(255,255,255,0.7);
    }

    @media (max-width: 992px) {
        .wall-shell {
            grid-template-columns: 1fr;
        }

        .wall-sidebar {
            position: static;
        }
    }

    .author-avatar {
        width: 50px;
        height: 50px;
        background: var(--primary-soft);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 600;
    }

    /* Animations */
    @keyframes slideInDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes fadeInRight {
        from {
            opacity: 0;
            transform: translateX(30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Mood Boosters */
    .mood-booster {
        position: fixed;
        bottom: 30px;
        right: 30px;
        z-index: 1000;
    }

    .mood-btn {
        width: 60px;
        height: 60px;
        background: var(--primary-soft);
        border: none;
        border-radius: 50%;
        color: white;
        font-size: 1.5rem;
        cursor: pointer;
        box-shadow: 0 10px 25px rgba(107, 140, 255, 0.4);
        transition: all 0.3s ease;
        animation: pulse 2s infinite;
    }

    .mood-btn:hover {
        transform: scale(1.1);
    }

    .mood-message {
        position: absolute;
        bottom: 80px;
        right: 0;
        background: white;
        padding: 15px 25px;
        border-radius: 30px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        white-space: nowrap;
        font-size: 1rem;
        color: var(--text-warm);
        border: 1px solid rgba(107, 140, 255, 0.2);
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        transform: translateY(10px);
    }

    .mood-booster:hover .mood-message {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    /* Breathing Exercise */
    .breathing-exercise {
        position: fixed;
        bottom: 30px;
        left: 30px;
        z-index: 1000;
    }

    .breathing-btn {
        width: 50px;
        height: 50px;
        background: var(--secondary-soothing);
        border: none;
        border-radius: 50%;
        color: white;
        font-size: 1.2rem;
        cursor: pointer;
        box-shadow: 0 10px 20px rgba(168, 213, 229, 0.4);
        transition: all 0.3s ease;
    }

    .breathing-btn:hover {
        transform: scale(1.1);
        background: #95C5D9;
    }

    /* Responsive */
    @media (max-width: 768px) {
        .hero-title {
            font-size: 2.5rem;
        }
        
        .hero-buttons {
            flex-direction: column;
            gap: 15px;
        }
        
        .btn-outline-calm {
            margin-left: 0;
        }
        
        .floating-card {
            display: none;
        }
        
        .stat-number {
            font-size: 2rem;
        }
    }

    /* Device adaptation */
    .hero-wrapper,
    .hero-content,
    .wall-shell,
    .wall-feed,
    .wall-sidebar,
    .wall-sidebar-panel,
    .support-wall-card,
    .modal-content {
        min-width: 0;
    }

    .hero-title,
    .hero-subtitle,
    .support-wall-card,
    .wall-sidebar-panel,
    .mood-message {
        overflow-wrap: anywhere;
    }

    .hero-buttons {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 12px;
    }

    .hero-buttons .btn,
    .btn-primary-calm,
    .btn-outline-calm {
        min-height: 46px;
    }

    .wall-shell {
        width: 100%;
    }

    .wall-sidebar {
        min-width: 0;
    }

    .mood-message {
        white-space: normal;
        width: min(280px, calc(100vw - 32px));
    }

    @media (max-width: 992px) {
        .hero-wrapper {
            min-height: auto;
            padding: 56px 0 36px;
        }

        .hero-content .row {
            gap: 24px;
        }

        .wall-sidebar {
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        }
    }

    @media (max-width: 768px) {
        .hero-title {
            font-size: clamp(2rem, 10vw, 2.5rem);
            line-height: 1.1;
        }

        .hero-subtitle {
            font-size: 1rem;
        }

        .hero-buttons .btn,
        .btn-primary-calm,
        .btn-outline-calm {
            width: 100%;
            margin-left: 0 !important;
        }

        .support-wall-section,
        .wall-shell {
            padding-left: 0;
            padding-right: 0;
        }

        .wall-sidebar {
            grid-template-columns: 1fr;
        }

        .mood-booster {
            right: 16px;
            bottom: max(16px, env(safe-area-inset-bottom));
        }

        .breathing-exercise {
            left: 16px;
            bottom: max(16px, env(safe-area-inset-bottom));
        }
    }

    @media (max-width: 480px) {
        .mood-btn,
        .breathing-btn {
            width: 48px;
            height: 48px;
            font-size: 1.05rem;
        }

        .mood-message {
            right: -8px;
            bottom: 62px;
            padding: 12px 14px;
            border-radius: 16px;
        }
    }
</style>

<!-- Hero Section -->
<div class="hero-wrapper">
    <div class="floating-shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
