        <div id="ratingSuccess" class="rating-success">
            <i class="fas fa-check-circle"></i>
            <h4>Thank you!</h4>
            <p style="color:#64748b;">Your rating has been saved.</p>
        </div>
    </div>
</div>

<div class="container-fluid" style="position:relative; z-index:1;">
    <div class="row g-0">

        <!-- ===== SIDEBAR ===== -->
        <div class="col-md-3 col-lg-2 sidebar">
            <div class="user-profile-container">

                <!-- Avatar -->
                <div class="avatar-circle" onclick="showProfile()" title="View profile">
                    <i class="fas fa-user-graduate"></i>
                </div>

                <!-- Name -->
                <h5 onclick="showProfile()" style="cursor:pointer;"><%= user.username %></h5>

                <!-- Student Badge -->
                <div class="badge-student" onclick="showProfile()" style="cursor:pointer;">
                    <i class="fas fa-circle" style="font-size:7px; color:#06d6a0;"></i>
                    Student
                </div>

                <div class="sidebar-divider"></div>

                <!-- Counselor Status -->
                <div id="counselorStatus" class="counselor-status-badge counselor-offline" onclick="checkCounselorStatus()" title="Click to refresh status">
                    <span class="realtime-indicator" style="background:#6c757d;"></span>
                    <span>Checking status…</span>
                </div>

                <!-- Chatbot hint -->
                <div class="auto-chatbot-text" onclick="startChatbot()" title="Start chatbot">
                    <i class="fas fa-robot"></i>
                    Auto-chatbot when offline
                </div>

                <div class="sidebar-divider"></div>

                <!-- Weather Widget -->
                <div class="weather-widget" onclick="refreshWeather()" title="Refresh weather">
                    <div>
                        <div class="temp">27°C</div>
                        <div class="condition">Mostly clear</div>
                    </div>
                    <i class="fas fa-sun"></i>
                </div>

            </div>
        </div>

        <!-- ===== MAIN CONTENT ===== -->
        <div class="col-md-9 col-lg-10 main-content">

            <!-- Welcome Section -->
            <div class="welcome-section">
                <div class="welcome-tag">
                    <i class="fas fa-circle"></i>
                    Safe & Confidential
                </div>
                <h1>Welcome back, <%= user.username %>! 👋</h1>
                <p>A safe, confidential space for students to seek support and connect with counselors</p>
                <div class="welcome-stats">
                    <div class="welcome-stat">
                        <div class="stat-num" id="onlineCounselorCountStat">—</div>
                        <div class="stat-label">Online Now</div>
                    </div>
                    <div class="welcome-stat">
                        <div class="stat-num">24/7</div>
                        <div class="stat-label">Chatbot Available</div>
                    </div>
                    <div class="welcome-stat">
                        <div class="stat-num">100%</div>
                        <div class="stat-label">Anonymous</div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="action-buttons">
                <button class="btn-chatbot" onclick="startChatbotWithAnimation(this)">
                    <i class="fas fa-robot fa-lg"></i>
                    <span>Start Chatbot Session</span>
                </button>
                <button class="btn-refresh" onclick="refreshCounselorsWithAnimation(this)" title="Refresh">
                    <i class="fas fa-sync-alt"></i>
                </button>
            </div>

            <!-- Recommended Resources -->
            <section class="recommendations-panel" aria-labelledby="recommendedResourcesTitle">
                <div class="recommendations-header">
                    <div class="recommendations-title">
                        <i class="fas fa-lightbulb"></i>
                        <div>
                            <h3 id="recommendedResourcesTitle">Recommended Resources</h3>
                            <p>Personalized support based on your recent issues and chat context</p>
                        </div>
                    </div>
                    <div class="recommendations-disclaimer" id="recommendationsDisclaimer">
                        These resources are informational and do not replace professional mental health support.
                    </div>
                </div>
                <div class="recommendation-chips" id="recommendationChips"></div>
                <div class="recommendations-grid" id="recommendationsGrid">
                    <div class="recommendations-state">
                        <i class="fas fa-spinner fa-spin me-2"></i>Loading recommendations...
                    </div>
                </div>
            </section>

            <!-- Counselors Section -->
            <div class="row">
                <div class="col-12">
                    <div class="section-title">
                        <div class="section-title-icon">
                            <i class="fas fa-comments"></i>
                        </div>
                        <h3>Online Counselors (<span id="onlineCounselorCount">0</span>)</h3>
                        <div class="section-title-line"></div>
                    </div>

                    <!-- Search -->
                    <div class="search-wrapper">
                        <i class="fas fa-search" id="searchIcon"></i>
                        <input type="text" id="searchCounselors"
                               placeholder="Search by name, specialization, education, or bio…"
                               oninput="debouncedSearchCounselors()"
                               onfocus="animateSearchFocus()"
                               onblur="animateSearchBlur()">
                    </div>

                    <div class="counselor-filter-panel">
                        <div class="filter-grid">
                            <div class="filter-control">
                                <label for="educationFilter">Education</label>
                                <select id="educationFilter" onchange="applyCounselorFilters()">
                                    <option value="all">All Education</option>
                                    <option>BA Psychology</option>
